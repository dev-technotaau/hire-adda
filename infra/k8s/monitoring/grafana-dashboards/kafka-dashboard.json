        {
          "expr": "sum(kafka_consumergroup_lag{namespace=\"hire-adda\",consumergroup=\"hire-adda-backend-group\"}) by (topic)",
          "legendFormat": "{{topic}}"
        }
      ]
    },
    {
      "title": "Total Consumer Lag",
      "type": "stat",
