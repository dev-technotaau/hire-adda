# Docker Mailserver Environment
# Copy to .env and fill in values

# Timezone (IST for India)
TZ=Asia/Kolkata

# Path to Let's Encrypt certificates on the host
# If using the app's certbot Docker volume, you need the volume mount path.
# For Hostinger VPS, this is typically where certbot stores certs:
LETSENCRYPT_PATH=/etc/letsencrypt

# Support email password (set during make mail-setup)
SUPPORT_EMAIL_PASSWORD=CHANGE_ME_TO_A_STRONG_PASSWORD
