{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Redis Memory Usage",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": { "unit": "bytes" }
      },
      "targets": [
        {
          "expr": "redis_memory_used_bytes",
          "legendFormat": "Used Memory"
        },
        {
          "expr": "redis_memory_max_bytes",
          "legendFormat": "Max Memory"
        },
        {
          "expr": "redis_memory_used_rss_bytes",
          "legendFormat": "RSS Memory"
        }
      ]
    },
    {
      "title": "Cache Hit Rate",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "max": 1,
          "min": 0,
          "thresholds": {
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 0.8 },
              { "color": "green", "value": 0.95 }
            ]
          }
        }
      },
      "targets": [
        {
          "expr": "redis_keyspace_hits_total / (redis_keyspace_hits_total + redis_keyspace_misses_total)",
          "legendFormat": "Hit Rate"
        }
      ]
    },
    {
      "title": "Connected Clients",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Clients"
        }
      ]
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 4 },
      "fieldConfig": {
        "defaults": { "unit": "s" }
      },
      "targets": [
        {
          "expr": "redis_uptime_in_seconds",
          "legendFormat": "Uptime"
        }
      ]
    },
    {
      "title": "Operations Per Second",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "targets": [
        {
          "expr": "rate(redis_commands_processed_total[5m])",
          "legendFormat": "Commands/s"
        },
        {
          "expr": "irate(redis_commands_processed_total[1m])",
          "legendFormat": "Commands/s (instant)"
        }
      ]
    },
    {
      "title": "Hit/Miss Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "targets": [
        {
          "expr": "rate(redis_keyspace_hits_total[5m])",
          "legendFormat": "Hits/s"
        },
        {
          "expr": "rate(redis_keyspace_misses_total[5m])",
          "legendFormat": "Misses/s"
        }
      ]
    },
    {
      "title": "Keys by Database",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "redis_db_keys",
          "legendFormat": "{{db}}"
        }
      ]
    },
    {
      "title": "Evicted Keys",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      },
      "targets": [
        {
          "expr": "rate(redis_evicted_keys_total[5m])",
          "legendFormat": "Evictions/s"
        },
        {
          "expr": "rate(redis_expired_keys_total[5m])",
          "legendFormat": "Expirations/s"
        }
      ]
    },
    {
      "title": "Network I/O",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      },
      "targets": [
        {
          "expr": "rate(redis_net_input_bytes_total[5m])",
          "legendFormat": "Input"
        },
        {
          "expr": "rate(redis_net_output_bytes_total[5m])",
          "legendFormat": "Output"
        }
      ]
    },
    {
      "title": "Blocked Clients",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "redis_blocked_clients",
          "legendFormat": "Blocked Clients"
        },
        {
          "expr": "redis_connected_clients",
          "legendFormat": "Connected Clients"
        }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["redis", "cache", "hire-adda"],
  "templating": { "list": [] },
  "time": { "from": "now-6h", "to": "now" },
  "title": "Redis",
  "uid": "tb-redis-compose"
}
