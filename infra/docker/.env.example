# ============================================================
# Hire Adda — Production Environment Variables
# Copy to .env and fill in all required values
# ============================================================
# Usage:
#   cp .env.example .env
#   nano .env  # fill in secrets
#   docker compose up -d
# ============================================================

# ─── GHCR Image Configuration ─────────────────────────────
# Used by docker-compose.yml to pull prebuilt images from GHCR.
# Tags are updated automatically by deploy.sh during blue-green/canary deploys.
GHCR_OWNER=chandreshkkhatri
BLUE_BACKEND_TAG=latest
BLUE_FRONTEND_TAG=latest
GREEN_BACKEND_TAG=latest
GREEN_FRONTEND_TAG=latest

# ─── Infrastructure Profiles ──────────────────────────────
# Controls which data services run as Docker containers on VPS.
# By default, all three use external cloud providers (Neon, Redis Cloud, Aiven).
# Add profiles as you gradually migrate to VPS:
#
#   Phase 1: COMPOSE_PROFILES=                                    (all cloud — initial deploy)
#   Phase 2: COMPOSE_PROFILES=vps-redis                           (Redis on VPS)
#   Phase 3: COMPOSE_PROFILES=vps-redis,vps-kafka                 (+ Kafka on VPS)
#   Phase 4: COMPOSE_PROFILES=vps-redis,vps-kafka,vps-postgres    (all on VPS)
#
# When a profile is active, the corresponding Docker container starts.
# When inactive, the backend connects to the cloud service via env vars below.
COMPOSE_PROFILES=

# ─── PostgreSQL ─────────────────────────────────────────────
# Cloud (Neon — default when COMPOSE_PROFILES does NOT include vps-postgres):
DATABASE_URL=postgresql://user:password@host.neon.tech/neondb?sslmode=verify-full
DATABASE_SSL_MODE=verify-full
DATABASE_POOL_SIZE=5
DATABASE_POOL_TIMEOUT=30
# VPS (uncomment + comment out cloud values when COMPOSE_PROFILES includes vps-postgres):
# POSTGRES_PASSWORD=CHANGE_ME_strong_password_here
# DATABASE_URL=postgresql://postgres:CHANGE_ME_strong_password_here@postgres:5432/hireadda?schema=public
# DATABASE_SSL_MODE=disable
# DATABASE_POOL_SIZE=10
# DATABASE_POOL_TIMEOUT=10

# ─── Redis ──────────────────────────────────────────────────
# Cloud (Redis Cloud — default when COMPOSE_PROFILES does NOT include vps-redis):
REDIS_HOST=redis-12345.c1.us-east-1-2.ec2.cloud.redislabs.com
REDIS_PORT=12345
REDIS_PASSWORD=your_redis_cloud_password
REDIS_TLS=true
REDIS_ENABLED=true
# VPS (uncomment + comment out cloud values when COMPOSE_PROFILES includes vps-redis):
# REDIS_HOST=redis
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_TLS=false
# REDIS_ENABLED=true

# ─── Apache Kafka ───────────────────────────────────────────
# Cloud (Aiven — default when COMPOSE_PROFILES does NOT include vps-kafka):
KAFKA_BROKERS=your-kafka.aivencloud.com:12345
KAFKA_CLIENT_ID=hire-adda-api
KAFKA_USERNAME=avnadmin
KAFKA_PASSWORD=your_aiven_password
KAFKA_SASL_MECHANISM=scram-sha-256
# VPS (uncomment + comment out cloud values when COMPOSE_PROFILES includes vps-kafka):
# KAFKA_BROKERS=kafka:9092
# KAFKA_CLIENT_ID=hire-adda-api
# KAFKA_USERNAME=
# KAFKA_PASSWORD=
# KAFKA_SASL_MECHANISM=plain

# ─── JWT Authentication ─────────────────────────────────────
JWT_SECRET=CHANGE_ME_min_32_characters_long_random_string
JWT_REFRESH_SECRET=CHANGE_ME_min_32_characters_refresh_secret
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
JWT_ALGORITHM=HS256
COOKIE_ACCESS_MAX_AGE_DAYS=7
COOKIE_REFRESH_MAX_AGE_DAYS=30
# RS256 keys (only required when JWT_ALGORITHM=RS256)
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=

# ─── Security Secrets ──────────────────────────────────────
COOKIE_SECRET=CHANGE_ME_min_32_characters_cookie_secret
CSRF_SECRET=CHANGE_ME_min_32_characters_csrf_secret
BFF_SECRET=CHANGE_ME_min_32_characters_bff_hex_secret

# ─── MFA & Security ────────────────────────────────────────
MFA_ISSUER=HireAdda
MFA_ENABLED=true
HIBP_ENABLED=true

# ─── Frontend Build Args (NEXT_PUBLIC_*) ────────────────────
# Baked into the Next.js image at CI build time (GitHub Secrets).
# Listed here for local dev builds via docker-compose.override.yml.
NEXT_PUBLIC_API_URL=https://api.hireadda.in/api/v1
NEXT_PUBLIC_SOCKET_URL=https://api.hireadda.in
NEXT_PUBLIC_APP_URL=https://hireadda.in
NEXT_PUBLIC_SUPPORT_EMAIL=support@hireadda.in

# Authentication (frontend)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
NEXT_PUBLIC_LINKEDIN_CLIENT_ID=
NEXT_PUBLIC_WEBAUTHN_RP_ID=hireadda.in

# Firebase (frontend)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# Analytics & Captcha (frontend)
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_FB_PIXEL_ID=
NEXT_PUBLIC_TURNSTILE_SITE_KEY=

# Sentry (build-time source map upload)
SENTRY_AUTH_TOKEN=
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Feature Flags (frontend)
NEXT_PUBLIC_ENABLE_MOCK_DATA=false
NEXT_PUBLIC_MAINTENANCE_MODE=false

# Public Assets & CDN (frontend)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
NEXT_PUBLIC_R2_PUBLIC_URL=
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
NEXT_PUBLIC_NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org

# Payments — Phase 2 (frontend)
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ─── Email (SMTP via Docker Mailserver) ─────────────────────
SMTP_USER=noreply@hireadda.in
SMTP_PASS=CHANGE_ME_email_password
SMTP_SECURE=false
EMAIL_FROM=noreply@hireadda.in
EMAIL_REPLY_TO=support@hireadda.in
SMTP_FROM_NAME=HireAdda
EMAIL_MAX_SEND_PER_HOUR=100
EMAIL_MAX_SEND_PER_DAY=300

# ─── OAuth ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/api/auth/google/callback

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=/api/auth/linkedin/callback

# ─── Firebase (backend service account) ─────────────────────
# JSON string: {"type": "service_account", ...}
FIREBASE_SERVICE_ACCOUNT=
FIREBASE_DATABASE_URL=

# ─── Google Cloud Platform ──────────────────────────────────
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION_ID=us-central1
DOCUMENT_AI_PROCESSOR_ID=
CLOUD_TALENT_TENANT_ID=

# ─── Google Analytics 4 (Measurement Protocol — backend) ────
GA_MEASUREMENT_ID=
GA_API_SECRET=

# ─── SMS & WhatsApp ─────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
META_WHATSAPP_PHONE_ID=
META_WHATSAPP_TOKEN=
ENABLE_TRANSACTIONAL_SMS=true

# ─── Web Push (VAPID) ──────────────────────────────────────
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@hireadda.in

# ─── Monitoring (Grafana) ─────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_grafana_password

# ─── Logs Dashboard (nginx basic auth for logs.hireadda.in) ──
# OpenSearch Dashboards has no built-in auth, so nginx basic auth protects it.
# Generate the htpasswd file on VPS after setup:
#   docker run --rm httpd:alpine htpasswd -Bn admin > nginx/htpasswd

# ─── Cloudinary (Image CDN) ────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Cloudflare R2 (Object Storage) ────────────────────────
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=talent-bridge-resumes
R2_PUBLIC_URL=

# ─── Cloudflare Turnstile (backend) ────────────────────────
CF_TURNSTILE_SECRET_KEY=

# ─── Webhooks ───────────────────────────────────────────────
WEBHOOK_SECRET=
WEBHOOK_CALLBACK_URL=

# ─── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_WINDOW_MS=300000
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10

# ─── Elasticsearch/OpenSearch (optional auth) ────────────────
# URL is set in docker-compose.yml (http://opensearch:9200).
# Only set credentials for external managed Elasticsearch.
# ELASTICSEARCH_USERNAME=
# ELASTICSEARCH_PASSWORD=
# ELASTICSEARCH_API_KEY=

# ─── Logging ───────────────────────────────────────────────
LOG_LEVEL=info
# LOG_AGGREGATION_URL=
# LOG_AGGREGATION_TOKEN=

# ─── OpenTelemetry / Tracing ──────────────────────────────
# Backend → OTel Collector → Tempo (local) + Honeycomb (cloud)
# The OTel Collector fans out traces to both destinations.
# OTEL_EXPORTER_OTLP_ENDPOINT is set in docker-compose.yml (otel-collector:4318).
# OTEL_EXPORTER_OTLP_HEADERS is not needed (collector handles Honeycomb auth).
OTEL_ENABLED=true
OTEL_SERVICE_NAME=hire-adda-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318/v1/traces
# OTEL_EXPORTER_OTLP_HEADERS=

# ─── Honeycomb (set your API key for cloud tracing) ───────
# Used by the OTel Collector to forward traces to Honeycomb.
HONEYCOMB_API_KEY=CHANGE_ME_honeycomb_api_key

# ─── Geocoding ─────────────────────────────────────────────
GEOCODING_PROVIDER=nominatim
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=HireAdda/1.0
# GOOGLE_GEOCODING_API_KEY=

# ─── Field-Level Encryption (optional, AES-256-GCM) ─────────
# 64-char hex string (32 bytes). Generate: openssl rand -hex 32
# FIELD_ENCRYPTION_KEY=

# ─── File Uploads ──────────────────────────────────────────
UPLOAD_MAX_SIZE=5242880
UPLOAD_DIR=uploads

# ─── Super Admin Seeding ───────────────────────────────────
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# ─── Backup ────────────────────────────────────────────────
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=30
OPENSEARCH_SNAPSHOT_REPO=hire_adda_repo

# ─── BullMQ Concurrency ───────────────────────────────────
BULLMQ_DEFAULT_JOB_OPTIONS_ATTEMPTS=3
BULLMQ_DEFAULT_JOB_OPTIONS_BACKOFF=1000
BULLMQ_REMOVE_ON_COMPLETE=100
BULLMQ_REMOVE_ON_FAIL=500
BULLMQ_EMAIL_CONCURRENCY=5
BULLMQ_SMS_CONCURRENCY=5
BULLMQ_FCM_CONCURRENCY=5
BULLMQ_WHATSAPP_CONCURRENCY=10
BULLMQ_WEBPUSH_CONCURRENCY=5
BULLMQ_INAPP_CONCURRENCY=10
BULLMQ_WEBHOOK_CONCURRENCY=5
BULLMQ_MATCHING_CONCURRENCY=3
BULLMQ_GEOCODING_CONCURRENCY=1
BULLMQ_RESUME_PARSE_CONCURRENCY=2
BULLMQ_ES_REINDEX_CONCURRENCY=3
BULLMQ_SCHEDULER_CONCURRENCY=2
BULLMQ_ONBOARDING_DRIP_CONCURRENCY=3
BULLMQ_IMAGE_PROCESSING_CONCURRENCY=2

# ─── OTP & Password Reset ──────────────────────────────────
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
OTP_MAX_RESEND_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
PASSWORD_RESET_EXPIRY_HOURS=1
PASSWORD_RESET_MAX_ATTEMPTS=5
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=15
SESSION_TIMEOUT_HOURS=24
MAX_SESSIONS_PER_USER=5

# ─── Password Validation ───────────────────────────────────
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true

# ─── IndexNow (instant indexing — Bing / Yandex / Naver / Seznam) ──
# Site key — must match the public file at /public/<KEY>.txt. Backend
# uses this to sign pings to api.indexnow.org on job / company / review
# mutations. Default ships out-of-the-box. Rotate by:
#   openssl rand -hex 16
# then rename public/<KEY>.txt + update this var to the new value.
INDEXNOW_KEY=c43d83f87126d18729b99c85048ac0f8
# Bearer token gating the frontend /api/indexnow-ping route — prevents
# random clients from burning our IndexNow quota. Generate via:
#   openssl rand -hex 32
# Then mirror the value as a GitHub Actions secret named
# INDEXNOW_PING_TOKEN so cd.yml's post-deploy ping step can authenticate.
INDEXNOW_PING_TOKEN=CHANGE_ME_64_char_hex_token_via_openssl_rand_hex_32
