# ============================================================
# UFW Rules Reference — Hire Adda VPS
# Generated by Ansible from group_vars/all.yml
# This file is a documentation reference; UFW is configured
# via community.general.ufw module in the playbook.
# ============================================================
# Default policy: deny incoming, allow outgoing
# Forwarding: ACCEPT (required for K3s pod networking)
# ============================================================

# ── Standard Rules ──
{% for rule in ufw_rules %}
# {{ rule.comment }}
# ufw {{ rule.rule }} {{ rule.port }}/{{ rule.proto }}
{% endfor %}

# ── K3s API (admin IPs only) ──
{% for ip in admin_ips %}
# ufw allow from {{ ip }} to any port 6443 proto tcp  # K3s API
{% endfor %}

# ── K3s Internal (localhost only) ──
# ufw allow from 127.0.0.1 to any port 10250 proto tcp  # kubelet API
# ufw allow from 127.0.0.1 to any port 10251 proto tcp  # kube-scheduler
# ufw allow from 127.0.0.1 to any port 10252 proto tcp  # kube-controller-manager
# ufw allow from 127.0.0.1 to any port 2379 proto tcp   # etcd client
# ufw allow from 127.0.0.1 to any port 2380 proto tcp   # etcd peer

# ── Summary ──
# Total open ports: {{ ufw_rules | length }} standard + {{ admin_ips | length }} admin K3s + 5 localhost K3s
