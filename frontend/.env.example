# ===================================
# Application Configuration
# ===================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_SOCKET_URL=http://localhost:5000
NEXT_PUBLIC_SUPPORT_EMAIL=support@talentbridge.com

# ===================================
# Authentication (OAuth & Security)
# ===================================
# Google
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
# LinkedIn
NEXT_PUBLIC_LINKEDIN_CLIENT_ID=
# Cloudflare Turnstile (CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# WebAuthn (Passkeys)
NEXT_PUBLIC_WEBAUTHN_RP_ID=localhost

# Note: JWT_SECRET and COOKIE_SECRET are backend-only and must NOT be exposed here.

# ===================================
# BFF (Backend-For-Frontend) — server-only, NOT prefixed with NEXT_PUBLIC_
# ===================================
# Internal backend URL for server-side BFF proxy calls (falls back to NEXT_PUBLIC_API_URL)
BACKEND_INTERNAL_URL=http://localhost:5000/api/v1
# Shared secret for CSRF bypass on BFF → backend calls (must match backend BFF_SECRET)
BFF_SECRET=your-bff-secret-key-min-32-characters-long-hexstring
# Cookie maxAge (days) — must match backend COOKIE_ACCESS_MAX_AGE_DAYS / COOKIE_REFRESH_MAX_AGE_DAYS
COOKIE_ACCESS_MAX_AGE_DAYS=7
COOKIE_REFRESH_MAX_AGE_DAYS=30

# ===================================
# Analytics & Monitoring
# ===================================
# Sentry (Frontend Project DSN)
NEXT_PUBLIC_SENTRY_DSN=
# Google Analytics 4
NEXT_PUBLIC_GA_ID=
# Google Tag Manager
NEXT_PUBLIC_GTM_ID=
# Facebook Pixel
NEXT_PUBLIC_FB_PIXEL_ID=
# OpenTelemetry (Tracing) — server-only, NOT prefixed with NEXT_PUBLIC_
OTEL_SERVICE_NAME=talent-bridge-frontend
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=your-honeycomb-api-key

# ===================================
# Payments (Phase 2)
# ===================================
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# ===================================
# Firebase (Analytics & FCM)
# ===================================
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=
# Firebase Realtime Database (for online presence)
NEXT_PUBLIC_FIREBASE_DATABASE_URL=
# Firebase Cloud Messaging (VAPID key for web push)
NEXT_PUBLIC_FIREBASE_VAPID_KEY=

# ===================================
# Feature Flags
# ===================================
NEXT_PUBLIC_ENABLE_MOCK_DATA=false
NEXT_PUBLIC_MAINTENANCE_MODE=false

# ===================================
# Public Assets & CDN
# ===================================
# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
# R2 Storage
NEXT_PUBLIC_R2_PUBLIC_URL=https://assets.talentbridge.com

# ===================================
# Web Push Notifications
# ===================================
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key-here

# ===================================
# Geocoding & Maps
# ===================================
NEXT_PUBLIC_NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
