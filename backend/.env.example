# ===================================
# Server Configuration
# ===================================
NODE_ENV=development
PORT=5000

# ===================================
# OpenSearch (Search Engine)
# ===================================
# Docker: http://localhost:9200 or http://opensearch:9200 (in compose)
# Managed: https://your-opensearch-endpoint:443
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
# API Key auth (Elasticsearch Cloud only, not used with OpenSearch)
ELASTICSEARCH_API_KEY=

# ===================================
# OAuth (Google & LinkedIn)
# ===================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/api/auth/google/callback

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=/api/auth/linkedin/callback

# ===================================
# Firebase Cloud Messaging
# ===================================
# FIREBASE_SERVICE_ACCOUNT={"type": "service_account", ...}
FIREBASE_SERVICE_ACCOUNT=
# Firebase Realtime Database URL (for online presence)
FIREBASE_DATABASE_URL=

# ===================================
# Google Cloud Platform
# ===================================
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION_ID=us-central1
# Document AI processor ID (for AI resume parsing)
DOCUMENT_AI_PROCESSOR_ID=

# ===================================
# Google Analytics 4 (Measurement Protocol)
# ===================================
GA_MEASUREMENT_ID=
GA_API_SECRET=

# ===================================
# SMS & WhatsApp (Twilio & Meta)
# ===================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

META_WHATSAPP_PHONE_ID=
META_WHATSAPP_TOKEN=

# SMS Cost Control
# Essential SMS (OTP, security alerts) are ALWAYS sent
# Transactional SMS (job matches, application updates) are sent only if enabled
# Set to 'false' to disable transactional SMS for all users
ENABLE_TRANSACTIONAL_SMS=true

# ===================================
# Web Push (VAPID)
# ===================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@talentbridge.com

# ===================================
# Apache Kafka (Event Streaming)
# ===================================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=talent-bridge-api
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SASL_MECHANISM=scram-sha-256




# ===================================
# Database (Any PostgreSQL Provider)
# ===================================
# Supabase (use POOLER URL, port 6543, NOT direct 5432):
#   Transaction mode: postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
#   Direct (migrations only): postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres
# Neon:      postgresql://[USER]:[PASSWORD]@[HOST].neon.tech/[DATABASE]?sslmode=require
# Railway:   postgresql://postgres:[PASSWORD]@[HOST].railway.app:5432/railway
# Local:     postgresql://postgres:password@localhost:5432/talent_bridge
DATABASE_URL="postgresql://postgres.PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true"
DATABASE_POOL_SIZE=5
DATABASE_POOL_TIMEOUT=30

# ===================================
# JWT Authentication
# ===================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# ===================================
# Redis (for caching & job queues)
# ===================================
# Local:     localhost
# Upstash:   [your-redis].upstash.io
# Redis Cloud: redis-[id].c[region].ec2.cloud.redislabs.com
# Railway:   [container].railway.internal
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# For cloud Redis with TLS (Upstash, Redis Cloud)
REDIS_TLS=false
# Set to false to disable Redis (app will use mock in development)
REDIS_ENABLED=true
# Full Redis URL (alternative to host/port/password)
# REDIS_URL=redis://default:password@host:port

# ===================================
# BullMQ Job Queue Settings
# ===================================
BULLMQ_DEFAULT_JOB_OPTIONS_ATTEMPTS=3
BULLMQ_DEFAULT_JOB_OPTIONS_BACKOFF=1000
BULLMQ_REMOVE_ON_COMPLETE=100
BULLMQ_REMOVE_ON_FAIL=500

# ===================================
# Email (SMTP)
# ===================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
EMAIL_FROM=noreply@talentbridge.com
SMTP_FROM_NAME="Talent Bridge"
SMTP_SECURE=false
EMAIL_MAX_SEND_PER_HOUR=100
EMAIL_MAX_SEND_PER_DAY=300

# ===================================
# File Uploads
# ===================================
UPLOAD_MAX_SIZE=5242880
UPLOAD_DIR=uploads

# ===================================
# Frontend URL (for CORS)
# ===================================
FRONTEND_URL=http://localhost:3000

# ===========================================
# CORS Configuration
# ===========================================
# Use * for development, specific origins for production
CORS_ORIGIN=*
# For production: CORS_ORIGIN=https://yourapp.com,https://admin.yourapp.com

# ===================================
# Sentry Error Monitoring
# ===================================
SENTRY_DSN=

# ===================================
# Cloudinary (Image Storage & CDN)
# ===================================
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===================================
# Cloudflare (R2 Storage & Turnstile)
# ===================================
# R2 Storage (S3 Compatible)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=talent-bridge-resumes
R2_PUBLIC_URL=https://assets.talentbridge.com

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Auth-specific rate limits
AUTH_RATE_LIMIT_WINDOW_MS=300000
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=debug
# Options: error, warn, info, http, verbose, debug, silly

# ===========================================
# Webhook Configuration
# ===========================================
WEBHOOK_SECRET=
WEBHOOK_CALLBACK_URL=

# ===========================================
# OTP Configuration
# ===========================================
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
OTP_MAX_RESEND_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# ===========================================
# Password Reset Configuration
# ===========================================
PASSWORD_RESET_EXPIRY_HOURS=1
PASSWORD_RESET_MAX_ATTEMPTS=5

# ===========================================
# Account Security Configuration
# ===========================================
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=15
SESSION_TIMEOUT_HOURS=24
MAX_SESSIONS_PER_USER=5

# ===========================================
# Password Validation Rules
# ===========================================
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true


# Turnstile (CAPTCHA)
CF_TURNSTILE_SECRET_KEY=

# ===================================
# Super Admin Seeding
# ===================================
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# ===================================
# OpenTelemetry (Distributed Tracing)
# ===================================
OTEL_ENABLED=false
OTEL_SERVICE_NAME=talent-bridge-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# Custom headers for OTel exporter (e.g., auth tokens for cloud providers)
OTEL_EXPORTER_OTLP_HEADERS=

# ===================================
# Feature Flags (Firebase Remote Config)
# ===================================
# Feature flags are managed via Firebase Remote Config
# No additional env config needed - uses FIREBASE_SERVICE_ACCOUNT

# ===================================
# MFA & Security
# ===================================
MFA_ISSUER="Talent Bridge"
MFA_ENABLED=true
# Number of days a trusted device token is valid (skip MFA on trusted devices)
MFA_TRUSTED_DEVICE_DAYS=30
HIBP_ENABLED=true

COOKIE_SECRET=your-cookie-secret-key-min-32-characters-long
CSRF_SECRET=your-csrf-secret-key-min-32-characters-long
JWT_ALGORITHM=HS256
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=

# ===================================
# WebAuthn (Passkeys)
# ===================================
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME="Talent Bridge"
WEBAUTHN_ORIGIN=http://localhost:3000

# ===================================
# Geocoding (Geo-Proximity Search)
# ===================================
# Provider: "nominatim" (free, OSM) or "google" (requires API key)
GEOCODING_PROVIDER=nominatim
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=TalentBridge/1.0
# For Google Geocoding (optional, set GEOCODING_PROVIDER=google to use)
GOOGLE_GEOCODING_API_KEY=

# ===================================
# Database Security
# ===================================
# SSL mode for PostgreSQL connection: disable, require, verify-ca, verify-full
DATABASE_SSL_MODE=disable
# 32-byte hex key for AES-256-GCM field-level encryption (optional)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# FIELD_ENCRYPTION_KEY=

# ===================================
# Centralized Log Aggregation
# ===================================
# HTTP endpoint for forwarding logs (e.g., Datadog, Loki, Logstash)
# LOG_AGGREGATION_URL=https://logs.example.com/api/v1/logs
# Bearer token for authenticating with the log aggregation endpoint
# LOG_AGGREGATION_TOKEN=

# ===================================
# Backup Configuration
# ===================================
# Directory for database backup files (relative to backend root)
BACKUP_DIR=./backups
# Number of days to retain backup files before cleanup
BACKUP_RETENTION_DAYS=30
# OpenSearch snapshot repository name
OPENSEARCH_SNAPSHOT_REPO=talent_bridge_repo
