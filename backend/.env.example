# ===================================
# Server Configuration
# ===================================
NODE_ENV=development
PORT=5000

# ===================================
# OpenSearch (Search Engine)
# ===================================
# Docker: http://localhost:9200 or http://opensearch:9200 (in compose)
# Managed: https://your-opensearch-endpoint:443
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
# API Key auth (Elasticsearch Cloud only, not used with OpenSearch)
ELASTICSEARCH_API_KEY=

# ===================================
# OAuth (Google & LinkedIn)
# ===================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=/api/auth/google/callback

LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CALLBACK_URL=/api/auth/linkedin/callback

# ===================================
# Firebase Cloud Messaging
# ===================================
# FIREBASE_SERVICE_ACCOUNT={"type": "service_account", ...}
FIREBASE_SERVICE_ACCOUNT=
# Firebase Realtime Database URL (for online presence)
FIREBASE_DATABASE_URL=

# ===================================
# Google Cloud Platform
# ===================================
GOOGLE_CLOUD_PROJECT_ID=
GOOGLE_CLOUD_LOCATION_ID=us-central1
# Document AI processor ID (for AI resume parsing)
DOCUMENT_AI_PROCESSOR_ID=

# ===================================
# Google Analytics 4 (Measurement Protocol)
# ===================================
GA_MEASUREMENT_ID=
GA_API_SECRET=

# ===================================
# SMS & WhatsApp (Twilio & Meta)
# ===================================
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

META_WHATSAPP_PHONE_ID=
META_WHATSAPP_TOKEN=

# SMS Cost Control
# Essential SMS (OTP, security alerts) are ALWAYS sent
# Transactional SMS (job matches, application updates) are sent only if enabled
# Set to 'false' to disable transactional SMS for all users
ENABLE_TRANSACTIONAL_SMS=true

# ===================================
# Web Push (VAPID)
# ===================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@hireadda.in

# ===================================
# Apache Kafka (Event Streaming)
# ===================================
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=hire-adda-api
KAFKA_USERNAME=
KAFKA_PASSWORD=
KAFKA_SASL_MECHANISM=scram-sha-256




# ===================================
# Database (Any PostgreSQL Provider)
# ===================================
# Neon:      postgresql://[USER]:[PASSWORD]@[HOST].neon.tech/[DATABASE]?sslmode=verify-full
# Supabase:  postgresql://postgres.[PROJECT]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true
# Railway:   postgresql://postgres:[PASSWORD]@[HOST].railway.app:5432/railway
# Local:     postgresql://postgres:password@localhost:5432/hire_adda
DATABASE_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=verify-full"
DIRECT_URL="postgresql://user:password@host.neon.tech/neondb?sslmode=verify-full"
DATABASE_POOL_SIZE=5
DATABASE_POOL_TIMEOUT=30

# ===================================
# JWT Authentication
# ===================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-secret-key-min-32-chars
JWT_REFRESH_EXPIRES_IN=30d

# Cookie maxAge (days) — how long auth cookies persist in the browser
COOKIE_ACCESS_MAX_AGE_DAYS=7
COOKIE_REFRESH_MAX_AGE_DAYS=30

# ===================================
# Redis (for caching & job queues)
# ===================================
# Local:     localhost
# Upstash:   [your-redis].upstash.io
# Redis Cloud: redis-[id].c[region].ec2.cloud.redislabs.com
# Railway:   [container].railway.internal
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
# For cloud Redis with TLS (Upstash, Redis Cloud)
REDIS_TLS=false
# Set to false to disable Redis (app will use mock in development)
REDIS_ENABLED=true
# Full Redis URL (alternative to host/port/password)
# REDIS_URL=redis://default:password@host:port

# ===================================
# BullMQ Job Queue Settings
# ===================================
BULLMQ_DEFAULT_JOB_OPTIONS_ATTEMPTS=3
BULLMQ_DEFAULT_JOB_OPTIONS_BACKOFF=1000
BULLMQ_REMOVE_ON_COMPLETE=100
BULLMQ_REMOVE_ON_FAIL=500
BULLMQ_EMAIL_CONCURRENCY=5
BULLMQ_SMS_CONCURRENCY=5
BULLMQ_FCM_CONCURRENCY=5
BULLMQ_WHATSAPP_CONCURRENCY=10
BULLMQ_WEBPUSH_CONCURRENCY=5
BULLMQ_INAPP_CONCURRENCY=10
BULLMQ_WEBHOOK_CONCURRENCY=5
BULLMQ_MATCHING_CONCURRENCY=3
BULLMQ_GEOCODING_CONCURRENCY=1
BULLMQ_RESUME_PARSE_CONCURRENCY=2
BULLMQ_ES_REINDEX_CONCURRENCY=3
BULLMQ_SCHEDULER_CONCURRENCY=2
BULLMQ_ONBOARDING_DRIP_CONCURRENCY=3
BULLMQ_IMAGE_PROCESSING_CONCURRENCY=2

# ===================================
# Email (SMTP)
# ===================================
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
EMAIL_FROM=noreply@hireadda.in
SMTP_FROM_NAME="Hire Adda"
SMTP_SECURE=false
EMAIL_MAX_SEND_PER_HOUR=100
EMAIL_MAX_SEND_PER_DAY=300

# ===================================
# File Uploads
# ===================================
UPLOAD_MAX_SIZE=5242880
UPLOAD_DIR=uploads

# ===================================
# Frontend URL (for CORS)
# ===================================
FRONTEND_URL=http://localhost:3000

# ===========================================
# CORS Configuration
# ===========================================
# Use * for development, specific origins for production
CORS_ORIGIN=*
# For production: CORS_ORIGIN=https://yourapp.com,https://admin.yourapp.com

# ===================================
# Sentry Error Monitoring
# ===================================
SENTRY_DSN=

# ===================================
# Cloudinary (Image Storage & CDN)
# ===================================
# Get credentials from: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ===================================
# Cloudflare (R2 Storage & Turnstile)
# ===================================
# R2 Storage (S3 Compatible)
CLOUDFLARE_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=talent-bridge-resumes
R2_PUBLIC_URL=https://assets.hireadda.in

# ===========================================
# Rate Limiting
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Auth-specific rate limits
AUTH_RATE_LIMIT_WINDOW_MS=300000
AUTH_RATE_LIMIT_MAX_ATTEMPTS=10

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=debug
# Options: error, warn, info, http, verbose, debug, silly

# ===========================================
# Webhook Configuration
# ===========================================
WEBHOOK_SECRET=
WEBHOOK_CALLBACK_URL=

# ===========================================
# OTP Configuration
# ===========================================
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
OTP_MAX_RESEND_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60

# ===========================================
# Password Reset Configuration
# ===========================================
PASSWORD_RESET_EXPIRY_HOURS=1
PASSWORD_RESET_MAX_ATTEMPTS=5

# ===========================================
# Account Security Configuration
# ===========================================
MAX_LOGIN_ATTEMPTS=5
ACCOUNT_LOCK_DURATION_MINUTES=15
SESSION_TIMEOUT_HOURS=24
MAX_SESSIONS_PER_USER=5

# ===========================================
# Password Validation Rules
# ===========================================
PASSWORD_MIN_LENGTH=8
PASSWORD_MAX_LENGTH=128
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBER=true
PASSWORD_REQUIRE_SPECIAL=true


# Turnstile (CAPTCHA)
CF_TURNSTILE_SECRET_KEY=

# ===================================
# Super Admin Seeding
# ===================================
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_PASSWORD=

# ===================================
# OpenTelemetry (Distributed Tracing)
# ===================================
OTEL_ENABLED=false
OTEL_SERVICE_NAME=hire-adda-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318/v1/traces
# Custom headers for OTel exporter (e.g., auth tokens for cloud providers)
OTEL_EXPORTER_OTLP_HEADERS=

# ===================================
# Feature Flags (Firebase Remote Config)
# ===================================
# Feature flags are managed via Firebase Remote Config
# No additional env config needed - uses FIREBASE_SERVICE_ACCOUNT

# ===================================
# MFA & Security
# ===================================
MFA_ISSUER="HireAdda"
MFA_ENABLED=true
# Number of days a trusted device token is valid (skip MFA on trusted devices)
MFA_TRUSTED_DEVICE_DAYS=30
HIBP_ENABLED=true

COOKIE_SECRET=your-cookie-secret-key-min-32-characters-long
CSRF_SECRET=your-csrf-secret-key-min-32-characters-long
# BFF (Backend-For-Frontend) shared secret — must match the frontend BFF_SECRET
# Used by Next.js API routes to bypass CSRF for server-to-server calls
BFF_SECRET=your-bff-secret-key-min-32-characters-long-hexstring
JWT_ALGORITHM=HS256
# JWT_PRIVATE_KEY=
# JWT_PUBLIC_KEY=

# ===================================
# WebAuthn (Passkeys)
# ===================================
WEBAUTHN_RP_ID=localhost
WEBAUTHN_RP_NAME="Hire Adda"
WEBAUTHN_ORIGIN=http://localhost:3000

# ===================================
# Geocoding (Geo-Proximity Search)
# ===================================
# Provider: "nominatim" (free, OSM) or "google" (requires API key)
GEOCODING_PROVIDER=nominatim
NOMINATIM_BASE_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT=HireAdda/1.0
# For Google Geocoding (optional, set GEOCODING_PROVIDER=google to use)
GOOGLE_GEOCODING_API_KEY=

# ===================================
# Database Security
# ===================================
# SSL mode for PostgreSQL connection: disable, require, verify-ca, verify-full
DATABASE_SSL_MODE=disable
# 32-byte hex key for AES-256-GCM field-level encryption (optional)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# FIELD_ENCRYPTION_KEY=

# ===================================
# Centralized Log Aggregation
# ===================================
# HTTP endpoint for forwarding logs (e.g., Datadog, Loki, Logstash)
# LOG_AGGREGATION_URL=https://logs.example.com/api/v1/logs
# Bearer token for authenticating with the log aggregation endpoint
# LOG_AGGREGATION_TOKEN=

# ===================================
# Backup Configuration
# ===================================
# Directory for database backup files (relative to backend root)
BACKUP_DIR=./backups
# Number of days to retain backup files before cleanup
BACKUP_RETENTION_DAYS=30
# OpenSearch snapshot repository name
OPENSEARCH_SNAPSHOT_REPO=hire_adda_repo

# ===================================
# Razorpay Payment Suite
# ===================================
# Test keys (current). Live keys come after GST verification.
RAZORPAY_KEY_ID=rzp_test_Sk4cIkFYK0nSES
RAZORPAY_KEY_SECRET=Uu7IGKGPwYhs1CSjGWkWV6kL
# Webhook secret — generated in Razorpay dashboard when adding the webhook
RAZORPAY_WEBHOOK_SECRET=
RAZORPAY_API_BASE_URL=https://api.razorpay.com/v1
RAZORPAY_DEFAULT_CURRENCY=INR
# Backend captures payments from webhook handler — keep this false
RAZORPAY_PAYMENT_CAPTURE_AUTO=false
# Toggle international payments after cross-border KYC is complete
RAZORPAY_INTERNATIONAL_ENABLED=false
RAZORPAY_NOTIFY_EMAIL=true
RAZORPAY_NOTIFY_SMS=true

# ===================================
# Hire Adda Billing Identity (Seller — printed on invoices)
# ===================================
# Parent: Opportunity Makers Group (Proprietorship of Harpreet Kaur)
HA_GSTIN=03EBLPK4190M1ZA
HA_LEGAL_NAME=Harpreet Kaur (Proprietor of M/S Opportunity Makers Group)
HA_TRADE_NAME=Hire Adda
HA_BILLING_LINE1=House No. 302, Village Dhogri Road
HA_BILLING_LINE2=Tehsil Nangal Salempur-1
HA_BILLING_CITY=Jalandhar
HA_BILLING_STATE_NAME=Punjab
HA_BILLING_STATE_CODE=03
HA_BILLING_PINCODE=144004
HA_BILLING_COUNTRY=India
HA_PAN=EBLPK4190M
HA_CIN=
HA_UDYAM_NUMBER=UDYAM-PB-10-0009173
HA_SUPPORT_EMAIL=support@hireadda.in
HA_SUPPORT_PHONE=

# ===================================
# Tax / GST / Invoice Settings
# ===================================
HA_HSN_SAC_CODE=998314
HA_GST_RATE_PERCENT=18
# Plan prices in DB are tax-inclusive (price already contains GST)
HA_GST_INCLUSIVE_PRICING=true
HA_INVOICE_PREFIX=HA
HA_FY_START_MONTH=4
# E-invoice (IRP) only required when turnover crosses ₹5 crore
HA_E_INVOICE_REQUIRED=false
HA_E_INVOICE_API_URL=
HA_E_INVOICE_USERNAME=
HA_E_INVOICE_PASSWORD=
HA_PLACE_OF_SUPPLY_DEFAULT_STATE=03

# ===================================
# Billing Operational Settings
# ===================================
# Refund window — buyer can request refund within N days post-purchase
BILLING_REFUND_WINDOW_DAYS=2
# Default expiry for super-admin custom plan offers (super-admin can override per offer)
BILLING_CUSTOM_OFFER_EXPIRY_DAYS=7
# Auto-renew dunning ladder: max retry attempts on failed renewal
BILLING_AUTO_RENEW_RETRY_MAX=4
# Days of grace period after renewal failure
BILLING_GRACE_PERIOD_DAYS=3
# EMI minimum order amount — Razorpay requires this; below = EMI hidden
BILLING_EMI_MIN_AMOUNT_PAISE=300000
# Pending order TTL — orders not paid within N minutes auto-expire
BILLING_ORDER_EXPIRY_MINUTES=30
BILLING_INVOICE_PDF_RETENTION_DAYS=2555
BILLING_FRAUD_ENABLED=true
BILLING_FRAUD_MULTI_ACCOUNT_THRESHOLD=3
BILLING_FRAUD_VELOCITY_WINDOW_SECONDS=300
BILLING_FRAUD_VELOCITY_THRESHOLD=5
BILLING_BIGQUERY_SYNC_ENABLED=false
# Reuse the existing analytics dataset (alongside user_events / application_events / job_events)
BILLING_BQ_DATASET=hire_adda_analytics
BILLING_BQ_TABLE=billing_events

BULLMQ_RAZORPAY_WEBHOOK_CONCURRENCY=5
BULLMQ_BILLING_REMINDER_CONCURRENCY=5
BULLMQ_BILLING_RETRY_CONCURRENCY=3
BULLMQ_INVOICE_GEN_CONCURRENCY=2
BULLMQ_SETTLEMENT_SYNC_CONCURRENCY=1
BULLMQ_FRAUD_SCAN_CONCURRENCY=3
BULLMQ_ENTITLEMENT_EXPIRY_CONCURRENCY=2
# Streams billing events (BILLING_*) into BigQuery — see jobs/bigquery-billing-sync.worker.ts
BULLMQ_BIGQUERY_BILLING_CONCURRENCY=5
# Defensive net for missing webhooks — polls Razorpay for CREATED/ATTEMPTED orders
BULLMQ_PAYMENT_STATUS_POLL_CONCURRENCY=2

# ===================================
# GST export-of-services treatment
# ===================================
# When true (LUT filed): 0% GST on export of services to non-Indian buyers.
# When false: 18% IGST applied to export. Can also be overridden at runtime
# via SystemConfig key `gst.export.with_lut`.
HA_GST_EXPORT_WITH_LUT=true

# ===================================
# IndexNow — instant indexing (Bing / Yandex / Naver / Seznam)
# ===================================
# Public-facing canonical URL — backend uses it for IndexNow host token,
# sitemap absolutes, and deep-link generators. Mirror the frontend's
# NEXT_PUBLIC_APP_URL value.
NEXT_PUBLIC_APP_URL=https://hireadda.in

# Site key — must match the public file at /public/<KEY>.txt on the
# frontend. Backend signs api.indexnow.org pings with this key on
# job / company / review mutations. Default ships out-of-box; rotate
# via:  openssl rand -hex 16  + rename the public key file.
INDEXNOW_KEY=c43d83f87126d18729b99c85048ac0f8
