{
  "name": "backend",
  "version": "1.0.0",
  "description": "Hire Adda Backend API",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "dist/index.js",
  "scripts": {
    "dev": "nodemon",
    "dev:debug": "cross-env DEBUG=* nodemon",
    "build": "prisma generate && tsc -p tsconfig.build.json && tsc-alias -p tsconfig.build.json && copyfiles -u 1 \"src/templates/**/*.hbs\" \"src/data/*.json\" dist/ && (npm run sentry:sourcemaps || true)",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "start:dev": "concurrently \"npm run dev\" \"npm run db:studio\"",
    "clean": "rimraf dist",
    "type-check": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,js}\"",
    "lint:fix": "eslint \"src/**/*.{ts,js}\" --fix",
    "format": "prettier --write \"src/**/*.{ts,js,json,md}\"",
    "test": "cross-env NODE_ENV=test jest",
    "test:watch": "cross-env NODE_ENV=test jest --watch",
    "test:cov": "cross-env NODE_ENV=test jest --coverage",
    "db:generate": "dotenv -- prisma generate",
    "db:push": "dotenv -- prisma db push",
    "db:migrate": "dotenv -- prisma migrate dev",
    "db:migrate:prod": "dotenv -- prisma migrate deploy",
    "db:studio": "dotenv -- prisma studio",
    "db:seed": "dotenv -- ts-node src/scripts/seed-super-admin.ts",
    "db:seed:dev": "dotenv -- ts-node src/scripts/seed-dev.ts",
    "backfill:cloud-talent": "dotenv -- ts-node src/scripts/backfill-cloud-talent.ts",
    "postinstall": "prisma generate",
    "prepare": "husky",
    "sentry:sourcemaps": "sentry-cli sourcemaps inject --org technotaau-rn --project hire-adda-api ./dist && sentry-cli sourcemaps upload --org technotaau-rn --project hire-adda-api ./dist"
  },
  "keywords": [],
  "author": "",
  "license": "UNLICENSED",
  "type": "commonjs",
  "overrides": {
    "bullmq": {
      "ioredis": "$ioredis"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.985.0",
    "@aws-sdk/lib-storage": "^3.985.0",
    "@aws-sdk/s3-request-presigner": "^3.985.0",
    "@bull-board/api": "^6.20.3",
    "@bull-board/express": "^6.20.3",
    "@google-cloud/bigquery": "^8.1.1",
    "@google-cloud/documentai": "^9.5.0",
    "@google-cloud/talent": "^7.1.1",
    "@opensearch-project/opensearch": "^2.12.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^7.3.0",
    "@sentry/cli": "^2.58.4",
    "@sentry/node": "^10.38.0",
    "@simplewebauthn/server": "^13.2.2",
    "@simplewebauthn/types": "^12.0.0",
    "@types/aws-sdk": "^0.0.42",
    "@types/passport-google-oauth20": "^2.0.17",
    "@types/passport-linkedin-oauth2": "^1.5.6",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "archiver": "^5.3.2",
    "axios": "^1.13.5",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.67.3",
    "cloudinary": "^2.9.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf-csrf": "^4.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.4",
    "exceljs": "^3.4.0",
    "express": "^5.2.1",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^8.2.1",
    "express-request-id": "^1.1.0",
    "firebase-admin": "^13.8.0",
    "handlebars": "^4.7.8",
    "helmet": "^8.1.0",
    "hpp": "^0.2.3",
    "ioredis": "^5.9.2",
    "isomorphic-dompurify": "^3.0.0-rc.2",
    "jsonwebtoken": "^9.0.3",
    "kafkajs": "^2.2.4",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "nodemailer": "^8.0.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "passport-linkedin-oauth2": "^2.0.0",
    "passport-local": "^1.0.0",
    "pdfkit": "^0.17.2",
