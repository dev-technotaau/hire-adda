<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }

        body {
            font-family: 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
            font-size: 11px;
            line-height: 1.5;
            color: #1a1a1a;
            max-width: 760px;
            margin: 0 auto;
        }

        a { color: #2563eb; text-decoration: none; }

        /* ── Header ── */
        .header {
            padding-bottom: 16px;
            margin-bottom: 18px;
            border-bottom: 2px solid #2563eb;
        }

        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            gap: 20px;
        }

        .name {
            font-size: 28px;
            font-weight: 700;
            color: #111827;
            letter-spacing: -0.5px;
            line-height: 1.2;
        }

        .headline {
            font-size: 13px;
            color: #4b5563;
            margin-top: 2px;
            font-weight: 400;
        }

        .contact-info {
            text-align: right;
            font-size: 10.5px;
            color: #374151;
            line-height: 1.7;
            flex-shrink: 0;
        }

        .contact-info a { color: #2563eb; }

        .contact-row {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 5px;
        }

        .contact-icon {
            font-size: 11px;
            width: 14px;
            text-align: center;
            color: #6b7280;
        }

        /* ── Sections ── */
        .section {
            margin-bottom: 16px;
            page-break-inside: avoid;
        }

        .section-title {
            font-size: 12px;
            font-weight: 700;
            color: #2563eb;
            text-transform: uppercase;
            letter-spacing: 1px;
            padding-bottom: 4px;
            margin-bottom: 10px;
            border-bottom: 1px solid #e5e7eb;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .section-icon {
            font-size: 12px;
            color: #2563eb;
        }

        /* ── Summary ── */
        .summary-text {
            font-size: 11px;
            color: #374151;
            line-height: 1.6;
        }

        /* ── Experience / Education ── */
        .entry {
            margin-bottom: 12px;
            page-break-inside: avoid;
        }

        .entry:last-child { margin-bottom: 0; }

        .entry-header {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 2px;
        }

        .entry-title {
            font-weight: 600;
            font-size: 11.5px;
            color: #111827;
        }

        .entry-subtitle {
            color: #4b5563;
            font-size: 11px;
        }

        .entry-date {
            font-size: 10px;
            color: #6b7280;
            white-space: nowrap;
            flex-shrink: 0;
        }

        .entry-description {
            font-size: 10.5px;
            color: #374151;
            margin-top: 3px;
            line-height: 1.5;
        }

        .entry-highlights {
            margin: 4px 0 0 0;
            padding-left: 16px;
            list-style-type: disc;
        }

        .entry-highlights li {
            font-size: 10.5px;
            color: #374151;
            margin-bottom: 1px;
            line-height: 1.4;
        }

        .entry-meta {
            font-size: 10px;
            color: #6b7280;
            margin-top: 2px;
        }

        /* ── Skills ── */
        .skills-list {
            display: flex;
            flex-wrap: wrap;
            gap: 6px;
        }

        .skill-tag {
            background: #eff6ff;
            color: #1e40af;
            padding: 3px 10px;
            border-radius: 3px;
            font-size: 10px;
            font-weight: 500;
            border: 1px solid #dbeafe;
        }

        /* ── Certifications / Awards ── */
        .cert-entry, .award-entry {
            margin-bottom: 6px;
            page-break-inside: avoid;
        }

        .cert-entry:last-child, .award-entry:last-child { margin-bottom: 0; }

        .cert-name, .award-title {
            font-weight: 600;
            font-size: 11px;
            color: #111827;
        }

        .cert-issuer, .award-issuer {
            color: #4b5563;
            font-size: 10.5px;
        }

        .cert-meta {
            font-size: 9.5px;
            color: #6b7280;
        }

        /* ── Projects ── */
        .project-entry {
            margin-bottom: 10px;
            page-break-inside: avoid;
        }

        .project-entry:last-child { margin-bottom: 0; }

        .project-name {
            font-weight: 600;
            font-size: 11px;
            color: #111827;
        }

        .project-role {
            color: #4b5563;
            font-size: 10.5px;
        }

        .project-tech {
            font-size: 10px;
            color: #2563eb;
            margin-top: 2px;
        }

        .project-desc {
            font-size: 10.5px;
            color: #374151;
            margin-top: 2px;
        }

        /* ── Languages ── */
        .lang-list {
            display: flex;
            flex-wrap: wrap;
            gap: 12px;
        }

        .lang-item {
            font-size: 11px;
            color: #374151;
        }

        .lang-proficiency {
            font-size: 10px;
            color: #6b7280;
        }

        /* ── Two-column layout for compact sections ── */
        .two-col {
            display: flex;
            gap: 30px;
        }

        .two-col > div { flex: 1; }
    </style>
</head>
<body>
    <!-- Header -->
    <div class="header">
        <div class="header-top">
            <div>
                <div class="name">{{fullName}}</div>
                {{#if headline}}<div class="headline">{{headline}}</div>{{/if}}
            </div>
            <div class="contact-info">
                {{#if email}}<div class="contact-row"><span class="contact-icon">&#9993;</span> {{email}}</div>{{/if}}
                {{#if phone}}<div class="contact-row"><span class="contact-icon">&#9742;</span> {{phone}}</div>{{/if}}
                {{#if location}}<div class="contact-row"><span class="contact-icon">&#9679;</span> {{location}}</div>{{/if}}
                {{#if linkedin}}<div class="contact-row"><a href="{{linkedin}}">LinkedIn</a></div>{{/if}}
                {{#if github}}<div class="contact-row"><a href="{{github}}">GitHub</a></div>{{/if}}
                {{#if portfolio}}<div class="contact-row"><a href="{{portfolio}}">Portfolio</a></div>{{/if}}
            </div>
        </div>
    </div>

    <!-- Professional Summary -->
    {{#if summary}}
    <div class="section">
        <div class="section-title"><span class="section-icon">&#9998;</span> Professional Summary</div>
        <p class="summary-text">{{summary}}</p>
    </div>
    {{/if}}

    <!-- Experience -->
    {{#if experience.length}}
    <div class="section">
        <div class="section-title"><span class="section-icon">&#9881;</span> Experience</div>
        {{#each experience}}
        <div class="entry">
            <div class="entry-header">
                <div>
                    <span class="entry-title">{{title}}</span>
                    <span class="entry-subtitle"> &mdash; {{company}}</span>
                    {{#if location}}<span class="entry-subtitle">, {{location}}</span>{{/if}}
                </div>
                <div class="entry-date">{{startDate}} &ndash; {{endDate}}</div>
            </div>
            {{#if description}}<div class="entry-description">{{description}}</div>{{/if}}
            {{#if highlights}}
            <ul class="entry-highlights">
                {{#each highlights}}
                <li>{{this}}</li>
                {{/each}}
            </ul>
            {{/if}}
        </div>
        {{/each}}
    </div>
    {{/if}}

    <!-- Education -->
    {{#if education.length}}
    <div class="section">
        <div class="section-title"><span class="section-icon">&#127891;</span> Education</div>
        {{#each education}}
        <div class="entry">
            <div class="entry-header">
                <div>
                    <span class="entry-title">{{degree}}</span>
                    {{#if field}}<span class="entry-subtitle"> in {{field}}</span>{{/if}}
                    <span class="entry-subtitle"> &mdash; {{institution}}</span>
                </div>
                {{#if year}}<div class="entry-date">{{year}}</div>{{/if}}
            </div>
            {{#if grade}}<div class="entry-meta">Grade: {{grade}}</div>{{/if}}
        </div>
        {{/each}}
    </div>
    {{/if}}

    <!-- Skills -->
    {{#if skills.length}}
    <div class="section">
        <div class="section-title"><span class="section-icon">&#9733;</span> Skills</div>
        <div class="skills-list">
            {{#each skills}}
            <span class="skill-tag">{{this}}</span>
            {{/each}}
        </div>
    </div>
    {{/if}}

    <!-- Certifications -->
    {{#if certifications.length}}
    <div class="section">
        <div class="section-title"><span class="section-icon">&#10004;</span> Certifications</div>
        {{#each certifications}}
        <div class="cert-entry">
            <div>
                <span class="cert-name">{{name}}</span>
                <span class="cert-issuer"> &mdash; {{issuer}}</span>
            </div>
            <div class="cert-meta">
                {{#if date}}{{date}}{{/if}}
                {{#if credentialId}} &middot; ID: {{credentialId}}{{/if}}
                {{#if url}} &middot; <a href="{{url}}">Verify</a>{{/if}}
            </div>
        </div>
        {{/each}}
    </div>
    {{/if}}

    <!-- Projects -->
    {{#if projects.length}}
    <div class="section">
        <div class="section-title"><span class="section-icon">&#128187;</span> Projects</div>
        {{#each projects}}
        <div class="project-entry">
            <div>
                <span class="project-name">{{name}}</span>
                {{#if role}}<span class="project-role"> &mdash; {{role}}</span>{{/if}}
                {{#if url}} &middot; <a href="{{url}}">Link</a>{{/if}}
            </div>
            {{#if technologies}}<div class="project-tech">{{#each technologies}}{{this}}{{#unless @last}}, {{/unless}}{{/each}}</div>{{/if}}
            {{#if description}}<div class="project-desc">{{description}}</div>{{/if}}
        </div>
        {{/each}}
    </div>
    {{/if}}

    <!-- Awards -->
    {{#if awards.length}}
    <div class="section">
        <div class="section-title"><span class="section-icon">&#127942;</span> Awards</div>
        {{#each awards}}
        <div class="award-entry">
            <div>
                <span class="award-title">{{title}}</span>
                {{#if issuer}}<span class="award-issuer"> &mdash; {{issuer}}</span>{{/if}}
                {{#if date}}<span class="cert-meta"> ({{date}})</span>{{/if}}
            </div>
            {{#if description}}<div class="entry-description">{{description}}</div>{{/if}}
        </div>
        {{/each}}
    </div>
    {{/if}}

    <!-- Languages -->
    {{#if languages.length}}
    <div class="section">
        <div class="section-title"><span class="section-icon">&#127760;</span> Languages</div>
        <div class="lang-list">
            {{#each languages}}
            <div class="lang-item">
                {{language}} <span class="lang-proficiency">({{proficiency}})</span>
            </div>
            {{/each}}
        </div>
    </div>
    {{/if}}
</body>
</html>
