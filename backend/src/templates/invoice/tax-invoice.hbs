<!doctype html>
<html lang="en-IN">
  <head>
    <meta charset="utf-8" />
    <title>Tax Invoice — {{invoiceNumber}}</title>
    <style>
      /* =========================================================
       * Tax-Invoice — Hire Adda enterprise-grade GST template
       * Print-safe A4 (210 × 297 mm). Designed for Puppeteer.
       * Brand palette mirrors the email-layout BRAND constants so
       * invoices and notifications feel like one product.
       * ========================================================= */
      @page {
        size: A4;
        margin: 12mm 14mm;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body {
        font-family: 'Inter', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
        font-size: 11px;
        line-height: 1.55;
        color: #1f2937;
        background: #fff;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .page {
        max-width: 800px;
        margin: 0 auto;
        padding: 24px 32px;
      }

      /* ---- Header / brand ---- */
      .header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 24px;
        padding-bottom: 18px;
        margin-bottom: 22px;
        border-bottom: 3px solid #2563EB;
      }
      .brand {
        display: flex;
        gap: 14px;
        align-items: flex-start;
      }
      .brand-logo {
        width: 56px;
        height: 56px;
        flex-shrink: 0;
        border-radius: 8px;
        background: #ffffff;
        padding: 4px;
        border: 1px solid #e5e7eb;
        box-shadow: 0 1px 2px rgba(0,0,0,0.04);
      }
      .brand-logo img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
      }
      .brand-text h1 {
        font-size: 22px;
        font-weight: 800;
        color: #2563EB;
        letter-spacing: -0.3px;
        margin-bottom: 2px;
      }
      .brand-text .legal-name {
        font-size: 11px;
        color: #4b5563;
        font-weight: 500;
      }
      .brand-text .tagline {
        color: #6b7280;
        font-size: 10px;
        margin-top: 4px;
      }
      .brand-text .web {
        color: #2563EB;
        font-size: 10px;
        font-weight: 600;
        margin-top: 2px;
      }
      .seller-meta {
        text-align: right;
        font-size: 10px;
        color: #4b5563;
      }
      .seller-meta .doc-title {
        font-size: 16px;
        font-weight: 800;
        color: #1f2937;
        letter-spacing: 0.5px;
        margin-bottom: 6px;
        text-transform: uppercase;
      }
      .seller-meta strong { color: #111827; }
      .seller-meta .reg-line { display: inline-block; margin-right: 8px; }
      .seller-meta .addr {
        margin-top: 8px;
        line-height: 1.5;
        max-width: 280px;
        margin-left: auto;
      }

      /* ---- Invoice meta strip ---- */
      .invoice-info {
        margin-bottom: 22px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
      }
      .invoice-info .item {
        background: linear-gradient(180deg, #ffffff 0%, #f8fafc 100%);
        border: 1px solid #e5e7eb;
        padding: 10px 12px;
        border-radius: 6px;
      }
      .invoice-info .item .label {
        text-transform: uppercase;
        font-size: 9px;
        color: #6b7280;
        letter-spacing: 0.7px;
        margin-bottom: 3px;
        font-weight: 600;
      }
      .invoice-info .item .value {
        font-size: 11px;
        font-weight: 700;
        color: #111827;
      }
      .invoice-info .item .value.mono {
        font-family: 'Roboto Mono', 'Courier New', monospace;
        font-size: 10.5px;
      }

      /* ---- Bill-to / reference grid ---- */
      .meta-grid {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 18px;
        margin-bottom: 22px;
      }
      .meta-block {
        background: #F8FAFC;
        padding: 14px 16px;
        border-radius: 8px;
        border: 1px solid #e2e8f0;
      }
      .meta-block h4 {
        text-transform: uppercase;
        font-size: 10px;
        color: #2563EB;
        letter-spacing: 0.7px;
        margin-bottom: 8px;
        font-weight: 700;
      }
      .meta-block .v {
        font-size: 11px;
        color: #1f2937;
        margin-bottom: 2px;
      }
      .meta-block .v strong { color: #111827; font-weight: 600; }
      .meta-block .name {
        font-weight: 700;
        font-size: 12.5px;
        color: #111827;
        margin-bottom: 4px;
      }

      /* ---- Notes (reverse charge / international) ---- */
      .gst-note {
        background: #FFFBEB;
        border: 1px solid #FCD34D;
        padding: 10px 14px;
        border-radius: 6px;
        font-size: 10px;
        color: #78350F;
        margin-bottom: 18px;
      }
      .gst-note.export {
        background: #EFF6FF;
        border-color: #93C5FD;
        color: #1E3A8A;
      }

      /* ---- Lines table ---- */
      table.lines {
        width: 100%;
        border-collapse: collapse;
        margin-bottom: 18px;
        border-radius: 6px;
        overflow: hidden;
        box-shadow: 0 0 0 1px #e5e7eb;
      }
      table.lines thead th {
        background: #2563EB;
        color: #fff;
        padding: 10px 8px;
        font-size: 10px;
        text-align: left;
        font-weight: 600;
        letter-spacing: 0.3px;
      }
      table.lines tbody td {
        padding: 10px 8px;
        font-size: 11px;
        border-bottom: 1px solid #e2e8f0;
        vertical-align: top;
      }
      table.lines tbody tr:last-child td { border-bottom: none; }
      table.lines tbody tr:nth-child(even) td { background: #fafbfc; }
      table.lines td.r, table.lines th.r { text-align: right; }
      table.lines td.c, table.lines th.c { text-align: center; }
      table.lines td.desc { font-weight: 500; color: #1f2937; }
      table.lines td.hsn { font-family: 'Roboto Mono', monospace; font-size: 10px; color: #4b5563; }

      /* ---- Totals ---- */
      .totals-wrap {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 24px;
        margin-bottom: 18px;
      }
      .totals-words {
        background: #F8FAFC;
        border: 1px dashed #cbd5e1;
        border-radius: 6px;
        padding: 14px 16px;
        font-size: 10.5px;
        color: #475569;
      }
      .totals-words .lbl {
        text-transform: uppercase;
        font-size: 9px;
        color: #6b7280;
        font-weight: 600;
        letter-spacing: 0.7px;
        margin-bottom: 4px;
      }
      .totals-words .val {
        font-size: 11px;
        color: #111827;
        font-weight: 600;
        font-style: italic;
      }
      .totals {
        align-self: start;
      }
      .totals .row {
        display: flex;
        justify-content: space-between;
        padding: 5px 0;
        font-size: 11px;
        border-bottom: 1px dotted #e5e7eb;
      }
      .totals .row:last-child { border-bottom: none; }
      .totals .row.tax { color: #475569; }
      .totals .row.discount { color: #047857; }
      .totals .row.grand {
        border: none;
        border-top: 2px solid #2563EB;
        margin-top: 4px;
        padding: 12px 0 4px;
        font-size: 14px;
        font-weight: 800;
        color: #2563EB;
      }
      .totals .row.paid { color: #059669; font-weight: 700; }
      .totals .row.refunded { color: #dc2626; }

      /* ---- Stamp / watermark ---- */
      .stamp-row {
        text-align: right;
        margin: 12px 0 8px;
      }
      .stamp {
        display: inline-block;
        padding: 6px 18px;
        border: 2px solid #059669;
        color: #059669;
        font-weight: 800;
        text-transform: uppercase;
        letter-spacing: 1.8px;
        font-size: 12px;
        transform: rotate(-3deg);
        border-radius: 4px;
      }
      .stamp.void-stamp {
        border-color: #dc2626;
        color: #dc2626;
      }
      .watermark {
        position: fixed;
        top: 50%;
        left: 50%;
        transform: translate(-50%, -50%) rotate(-25deg);
        font-size: 120px;
        font-weight: 900;
        color: rgba(220, 38, 38, 0.07);
        letter-spacing: 16px;
        pointer-events: none;
        z-index: 0;
        white-space: nowrap;
      }

      /* ---- Payment-instrument card ---- */
      .pay-card {
        margin: 14px 0;
        padding: 12px 16px;
        background: linear-gradient(135deg, #F0F9FF 0%, #DBEAFE 100%);
        border: 1px solid #BAE6FD;
        border-radius: 8px;
        font-size: 10.5px;
        color: #1e3a8a;
        display: grid;
        grid-template-columns: auto 1fr auto;
        gap: 14px;
        align-items: center;
      }
      .pay-card .badge {
        background: #2563EB;
        color: #fff;
        padding: 4px 10px;
        border-radius: 4px;
        font-weight: 700;
        font-size: 10px;
        letter-spacing: 0.5px;
        text-transform: uppercase;
      }
      .pay-card .ref { color: #4b5563; }
      .pay-card .ref strong { color: #1e3a8a; font-family: 'Roboto Mono', monospace; }

      /* ---- e-Invoice block ---- */
      .e-invoice {
        margin: 18px 0 8px;
        padding: 12px 16px;
        background: #F0FDF4;
        border: 1px solid #86EFAC;
        border-radius: 6px;
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 14px;
        align-items: center;
        font-size: 10px;
        color: #065F46;
      }
      .e-invoice .lbl {
        font-size: 9px;
        text-transform: uppercase;
        letter-spacing: 0.7px;
        color: #047857;
        font-weight: 700;
        margin-bottom: 2px;
      }
      .e-invoice .v {
        font-family: 'Roboto Mono', monospace;
        font-size: 10px;
        color: #065F46;
        font-weight: 600;
        word-break: break-all;
      }
      .e-invoice .qr {
        width: 88px;
        height: 88px;
        background: #fff;
        border: 1px solid #86EFAC;
        border-radius: 4px;
        padding: 4px;
      }
      .e-invoice .qr img {
        width: 100%;
        height: 100%;
        object-fit: contain;
        display: block;
      }

      /* ---- Footer ---- */
      .footer {
        margin-top: 26px;
        padding-top: 18px;
        border-top: 1px solid #e2e8f0;
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 20px;
        font-size: 10px;
        color: #4b5563;
      }
      .footer h5 {
        text-transform: uppercase;
        font-size: 10px;
        color: #111827;
        margin-bottom: 6px;
        letter-spacing: 0.6px;
        font-weight: 700;
      }
      .footer p {
        margin-bottom: 4px;
        line-height: 1.5;
      }
      .footer .terms ol {
        padding-left: 14px;
        margin: 0;
      }
      .footer .terms ol li {
        margin-bottom: 3px;
      }
      .footer-bottom {
        margin-top: 18px;
        padding-top: 12px;
        border-top: 1px dashed #e2e8f0;
        text-align: center;
        font-size: 9px;
        color: #9ca3af;
      }
      .footer-bottom strong { color: #4b5563; }
    </style>
  </head>
  <body>
    {{#if isVoided}}<div class="watermark">VOID</div>{{/if}}
    <div class="page">
      <!-- =================== Header =================== -->
      <div class="header">
        <div class="brand">
          {{#if seller.logoUrl}}
            <div class="brand-logo">
              <img src="{{seller.logoUrl}}" alt="{{seller.tradeName}}" />
            </div>
          {{/if}}
          <div class="brand-text">
            <h1>{{seller.tradeName}}</h1>
            <div class="legal-name">A unit of {{seller.legalName}}</div>
            {{#if seller.tagline}}<div class="tagline">{{seller.tagline}}</div>{{/if}}
            {{#if seller.website}}<div class="web">{{seller.website}}</div>{{/if}}
          </div>
        </div>
        <div class="seller-meta">
          <div class="doc-title">{{docTitle}}</div>
          <div><strong>GSTIN:</strong> {{seller.gstin}}</div>
          {{#if seller.pan}}<div class="reg-line"><strong>PAN:</strong> {{seller.pan}}</div>{{/if}}
          {{#if seller.cin}}<div class="reg-line"><strong>CIN:</strong> {{seller.cin}}</div>{{/if}}
          {{#if seller.udyam}}<div><strong>UDYAM:</strong> {{seller.udyam}}</div>{{/if}}
          <div class="addr">
            {{seller.line1}}{{#if seller.line2}}, {{seller.line2}}{{/if}}<br/>
            {{seller.city}}, {{seller.stateName}} - {{seller.pincode}}<br/>
            {{seller.country}}
          </div>
          {{#if seller.supportEmail}}<div style="margin-top:6px;"><strong>Email:</strong> {{seller.supportEmail}}</div>{{/if}}
          {{#if seller.supportPhone}}<div><strong>Phone:</strong> {{seller.supportPhone}}</div>{{/if}}
        </div>
      </div>

      <!-- =================== Invoice meta =================== -->
      <div class="invoice-info">
        <div class="item">
          <div class="label">Invoice No.</div>
          <div class="value mono">{{invoiceNumber}}</div>
        </div>
        <div class="item">
          <div class="label">Issued On</div>
          <div class="value">{{issuedAtFormatted}}</div>
        </div>
        <div class="item">
          <div class="label">Place of Supply</div>
          <div class="value">{{placeOfSupplyLabel}}</div>
        </div>
        <div class="item">
          <div class="label">{{#if isReverseCharge}}Reverse Charge{{else}}Currency{{/if}}</div>
          <div class="value">{{#if isReverseCharge}}Yes{{else}}{{currency}}{{/if}}</div>
        </div>
      </div>

      <!-- =================== Bill-to / reference =================== -->
      <div class="meta-grid">
        <div class="meta-block">
          <h4>Bill To</h4>
          <div class="name">{{buyer.legalName}}</div>
          {{#if buyer.gstin}}<div class="v"><strong>GSTIN:</strong> {{buyer.gstin}}</div>{{/if}}
          {{#if buyer.email}}<div class="v">{{buyer.email}}</div>{{/if}}
          {{#if buyer.phone}}<div class="v">{{buyer.phone}}</div>{{/if}}
          {{#if buyer.line1}}<div class="v" style="margin-top:6px;">{{buyer.line1}}{{#if buyer.line2}}, {{buyer.line2}}{{/if}}</div>{{/if}}
          {{#if buyer.city}}<div class="v">{{buyer.city}}{{#if buyer.stateName}}, {{buyer.stateName}}{{/if}} {{buyer.pincode}}</div>{{/if}}
          {{#if buyer.country}}<div class="v">{{buyer.country}}</div>{{/if}}
        </div>
        <div class="meta-block">
          <h4>Reference</h4>
          {{#if order.receiptNumber}}<div class="v"><strong>Order Receipt:</strong> {{order.receiptNumber}}</div>{{/if}}
          {{#if order.razorpayOrderId}}<div class="v"><strong>Razorpay Order:</strong> <span style="font-family:'Roboto Mono',monospace;font-size:10px;">{{order.razorpayOrderId}}</span></div>{{/if}}
          {{#if subscription.id}}<div class="v"><strong>Subscription:</strong> {{subscription.id}}</div>{{/if}}
          {{#if periodLabel}}<div class="v"><strong>Period:</strong> {{periodLabel}}</div>{{/if}}
          {{#if planSnapshot.name}}<div class="v"><strong>Plan:</strong> {{planSnapshot.name}}</div>{{/if}}
        </div>
      </div>

      <!-- =================== Notes =================== -->
      {{#if reverseChargeNote}}<div class="gst-note">{{reverseChargeNote}}</div>{{/if}}
      {{#if exportNote}}<div class="gst-note export">{{exportNote}}</div>{{/if}}

      <!-- =================== Lines =================== -->
      <table class="lines">
        <thead>
          <tr>
            <th class="c" style="width:30px;">#</th>
            <th>Description</th>
            <th class="c">HSN/SAC</th>
            <th class="r">Qty</th>
            <th class="r">Rate</th>
            <th class="r">Taxable</th>
            <th class="r">CGST</th>
            <th class="r">SGST</th>
            <th class="r">IGST</th>
            <th class="r">Total</th>
          </tr>
        </thead>
        <tbody>
          {{#each lines}}
            <tr>
              <td class="c">{{add @index 1}}</td>
              <td class="desc">{{this.description}}</td>
              <td class="hsn c">{{this.hsnSac}}</td>
              <td class="r">{{this.quantity}}</td>
              <td class="r">{{this.rateFormatted}}</td>
              <td class="r">{{this.taxableFormatted}}</td>
              <td class="r">{{#if this.cgstFormatted}}{{this.cgstFormatted}}{{else}}—{{/if}}</td>
              <td class="r">{{#if this.sgstFormatted}}{{this.sgstFormatted}}{{else}}—{{/if}}</td>
              <td class="r">{{#if this.igstFormatted}}{{this.igstFormatted}}{{else}}—{{/if}}</td>
              <td class="r"><strong>{{this.totalFormatted}}</strong></td>
            </tr>
          {{/each}}
        </tbody>
      </table>

      <!-- =================== Totals + amount-in-words =================== -->
      <div class="totals-wrap">
        <div class="totals-words">
          <div class="lbl">Amount in Words</div>
          <div class="val">{{totals.grandInWords}}</div>
        </div>
        <div class="totals">
          <div class="row"><span>Subtotal (taxable)</span><span>{{totals.taxableFormatted}}</span></div>
          {{#if totals.discountFormatted}}<div class="row discount"><span>Discount</span><span>− {{totals.discountFormatted}}</span></div>{{/if}}
          {{#if totals.cgstFormatted}}<div class="row tax"><span>CGST {{totals.cgstPercent}}%</span><span>{{totals.cgstFormatted}}</span></div>{{/if}}
          {{#if totals.sgstFormatted}}<div class="row tax"><span>SGST {{totals.sgstPercent}}%</span><span>{{totals.sgstFormatted}}</span></div>{{/if}}
          {{#if totals.igstFormatted}}<div class="row tax"><span>IGST {{totals.igstPercent}}%</span><span>{{totals.igstFormatted}}</span></div>{{/if}}
          {{#if totals.cessFormatted}}<div class="row tax"><span>Cess</span><span>{{totals.cessFormatted}}</span></div>{{/if}}
          <div class="row grand"><span>Grand Total</span><span>{{totals.grandFormatted}}</span></div>
          {{#if totals.paid}}<div class="row paid"><span>Paid</span><span>− {{totals.paidFormatted}}</span></div>{{/if}}
          {{#if totals.refunded}}<div class="row refunded"><span>Refunded</span><span>− {{totals.refundedFormatted}}</span></div>{{/if}}
        </div>
      </div>

      <!-- =================== Payment instrument =================== -->
      {{#if payment.razorpayPaymentId}}
      <div class="pay-card">
        <span class="badge">{{payment.method}}</span>
        <div class="ref">
          {{#if payment.cardLast4}}Card ending <strong>{{payment.cardLast4}}</strong>{{#if payment.cardNetwork}} · {{payment.cardNetwork}}{{/if}}<br/>{{/if}}
          {{#if payment.vpa}}UPI <strong>{{payment.vpa}}</strong><br/>{{/if}}
          {{#if payment.bank}}Net Banking · <strong>{{payment.bank}}</strong><br/>{{/if}}
          {{#if payment.wallet}}Wallet · <strong>{{payment.wallet}}</strong><br/>{{/if}}
          Payment ID <strong>{{payment.razorpayPaymentId}}</strong>
          {{#if payment.capturedAtFormatted}}<br/>Captured on {{payment.capturedAtFormatted}}{{/if}}
        </div>
        <div></div>
      </div>
      {{/if}}

      <!-- =================== Stamps =================== -->
      {{#if isPaid}}
        <div class="stamp-row"><span class="stamp">Paid</span></div>
      {{/if}}
      {{#if isVoided}}
        <div class="stamp-row"><span class="stamp void-stamp">Voided</span></div>
      {{/if}}

      <!-- =================== e-Invoice block =================== -->
      {{#if eInvoice.irn}}
      <div class="e-invoice">
        <div>
          <div class="lbl">e-Invoice IRN</div>
          <div class="v">{{eInvoice.irn}}</div>
          <div class="lbl" style="margin-top:6px;">Acknowledgement</div>
          <div class="v">{{eInvoice.ackNo}}{{#if eInvoice.ackDate}} · {{eInvoice.ackDate}}{{/if}}</div>
        </div>
        {{#if eInvoice.qrUrl}}
          <div class="qr"><img src="{{eInvoice.qrUrl}}" alt="e-Invoice QR" /></div>
        {{/if}}
      </div>
      {{/if}}

      <!-- =================== Footer =================== -->
      <div class="footer">
        <div class="terms">
          <h5>Terms &amp; Conditions</h5>
          <ol>
            <li>Tax-inclusive pricing. GST charged as applicable per the Place of Supply rules.</li>
            <li>Refunds processed per the {{seller.tradeName}} refund policy ({{refundWindowDays}} days).</li>
            <li>This is a system-generated tax invoice — no signature required.</li>
            <li>Disputes must be raised within 30 days at {{seller.supportEmail}}.</li>
          </ol>
        </div>
        <div>
          <h5>Settlement</h5>
          <p>Collected via Razorpay Software Pvt. Ltd.</p>
          <p>Settled to <strong>{{seller.legalName}}</strong>.</p>
          {{#if seller.bankName}}<p>Bank: {{seller.bankName}}</p>{{/if}}
        </div>
        <div>
          <h5>Support</h5>
          {{#if seller.supportEmail}}<p>{{seller.supportEmail}}</p>{{/if}}
          {{#if seller.supportPhone}}<p>{{seller.supportPhone}}</p>{{/if}}
          {{#if seller.website}}<p>{{seller.website}}</p>{{/if}}
        </div>
      </div>

      <div class="footer-bottom">
        <strong>{{seller.legalName}}</strong> · GSTIN {{seller.gstin}}
        {{#if seller.cin}} · CIN {{seller.cin}}{{/if}}
        {{#if seller.pan}} · PAN {{seller.pan}}{{/if}}
        <br/>
        Generated on {{generatedAt}} · Invoice copy retained for {{retentionYears}} years per GST Act §36
      </div>
    </div>
  </body>
</html>
