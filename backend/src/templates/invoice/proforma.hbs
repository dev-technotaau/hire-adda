<!doctype html>
<html lang="en-IN">
  <head>
    <meta charset="utf-8" />
    <title>Proforma Invoice — {{invoiceNumber}}</title>
    <style>
      @page { size: A4; margin: 12mm 14mm; }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body {
        font-family: 'Inter', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
        font-size: 11px;
        line-height: 1.55;
        color: #1f2937;
        background: #fff;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .page { max-width: 800px; margin: 0 auto; padding: 24px 32px; position: relative; }

      .watermark {
        position: fixed;
        top: 50%; left: 50%;
        transform: translate(-50%, -50%) rotate(-25deg);
        font-size: 110px; font-weight: 900;
        color: rgba(245, 158, 11, 0.08);
        letter-spacing: 18px;
        pointer-events: none;
        z-index: 0;
        white-space: nowrap;
      }

      .header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 24px;
        padding-bottom: 18px;
        margin-bottom: 22px;
        border-bottom: 3px solid #F59E0B;
      }
      .brand { display: flex; gap: 14px; align-items: flex-start; }
      .brand-logo {
        width: 56px; height: 56px; border-radius: 8px;
        background: #fff; padding: 4px; border: 1px solid #e5e7eb;
      }
      .brand-logo img { width: 100%; height: 100%; object-fit: contain; display: block; }
      .brand-text h1 { font-size: 22px; font-weight: 800; color: #D97706; letter-spacing: -0.3px; }
      .brand-text .legal-name { font-size: 11px; color: #4b5563; font-weight: 500; }
      .brand-text .web { color: #D97706; font-size: 10px; font-weight: 600; margin-top: 4px; }
      .seller-meta { text-align: right; font-size: 10px; color: #4b5563; }
      .seller-meta .doc-title {
        font-size: 16px; font-weight: 800; color: #92400E;
        text-transform: uppercase; letter-spacing: 0.6px; margin-bottom: 6px;
      }

      .proforma-banner {
        background: linear-gradient(135deg, #FEF3C7 0%, #FDE68A 100%);
        border: 1px solid #F59E0B;
        padding: 14px 18px;
        border-radius: 8px;
        margin-bottom: 22px;
        font-size: 11px;
        color: #78350F;
      }
      .proforma-banner strong { color: #92400E; }

      .invoice-info {
        margin-bottom: 22px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
      }
      .invoice-info .item {
        background: #FFFBEB; border: 1px solid #FDE68A;
        padding: 10px 12px; border-radius: 6px;
      }
      .invoice-info .item .label {
        text-transform: uppercase; font-size: 9px;
        color: #B45309; letter-spacing: 0.7px;
        margin-bottom: 3px; font-weight: 600;
      }
      .invoice-info .item .value { font-size: 11px; font-weight: 700; color: #78350F; }
      .invoice-info .item .value.mono { font-family: 'Roboto Mono', monospace; font-size: 10.5px; }

      .meta-grid {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: 18px; margin-bottom: 22px;
      }
      .meta-block {
        background: #FFFBEB; padding: 14px 16px;
        border-radius: 8px; border: 1px solid #FDE68A;
      }
      .meta-block h4 {
        text-transform: uppercase; font-size: 10px;
        color: #D97706; letter-spacing: 0.7px;
        margin-bottom: 8px; font-weight: 700;
      }
      .meta-block .v { font-size: 11px; color: #1f2937; margin-bottom: 2px; }
      .meta-block .name { font-weight: 700; font-size: 12.5px; color: #111827; margin-bottom: 4px; }

      table.lines {
        width: 100%; border-collapse: collapse;
        margin-bottom: 18px;
        border-radius: 6px; overflow: hidden;
        box-shadow: 0 0 0 1px #FDE68A;
      }
      table.lines thead th {
        background: #F59E0B; color: #fff;
        padding: 10px 8px; font-size: 10px;
        text-align: left; font-weight: 600;
      }
      table.lines tbody td {
        padding: 10px 8px; font-size: 11px;
        border-bottom: 1px solid #FDE68A;
        vertical-align: top;
      }
      table.lines tbody tr:nth-child(even) td { background: #FFFBEB; }
      table.lines td.r, table.lines th.r { text-align: right; }
      table.lines td.c, table.lines th.c { text-align: center; }

      .totals-wrap {
        display: grid;
        grid-template-columns: 1.2fr 1fr;
        gap: 24px;
        margin-bottom: 18px;
      }
      .totals-words {
        background: #FFFBEB; border: 1px dashed #F59E0B;
        border-radius: 6px; padding: 14px 16px;
        font-size: 10.5px; color: #92400E;
      }
      .totals-words .lbl {
        text-transform: uppercase; font-size: 9px;
        color: #D97706; font-weight: 700;
        letter-spacing: 0.7px; margin-bottom: 4px;
      }
      .totals .row {
        display: flex; justify-content: space-between;
        padding: 5px 0; font-size: 11px;
        border-bottom: 1px dotted #FDE68A;
      }
      .totals .row.tax { color: #92400E; }
      .totals .row.grand {
        border: none; border-top: 2px solid #F59E0B;
        margin-top: 4px; padding: 12px 0 4px;
        font-size: 14px; font-weight: 800; color: #D97706;
      }

      .pay-instructions {
        margin: 18px 0;
        padding: 14px 18px;
        background: #F0F9FF;
        border: 1px solid #BAE6FD;
        border-radius: 8px;
        font-size: 11px;
        color: #1E3A8A;
      }
      .pay-instructions h5 {
        text-transform: uppercase; font-size: 10px;
        color: #1E40AF; letter-spacing: 0.6px;
        margin-bottom: 6px; font-weight: 700;
      }

      .footer {
        margin-top: 26px; padding-top: 18px;
        border-top: 1px solid #e5e7eb;
        display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
        font-size: 10px; color: #4b5563;
      }
      .footer h5 {
        text-transform: uppercase; font-size: 10px;
        color: #111827; margin-bottom: 6px;
        letter-spacing: 0.6px; font-weight: 700;
      }
      .footer-bottom {
        margin-top: 18px; padding-top: 12px;
        border-top: 1px dashed #e5e7eb;
        text-align: center; font-size: 9px; color: #9ca3af;
      }
      .footer-bottom strong { color: #4b5563; }
    </style>
  </head>
  <body>
    <div class="watermark">PROFORMA</div>
    <div class="page">
      <div class="header">
        <div class="brand">
          {{#if seller.logoUrl}}<div class="brand-logo"><img src="{{seller.logoUrl}}" alt="{{seller.tradeName}}" /></div>{{/if}}
          <div class="brand-text">
            <h1>{{seller.tradeName}}</h1>
            <div class="legal-name">A unit of {{seller.legalName}}</div>
            {{#if seller.website}}<div class="web">{{seller.website}}</div>{{/if}}
          </div>
        </div>
        <div class="seller-meta">
          <div class="doc-title">Proforma Invoice</div>
          <div><strong>GSTIN:</strong> {{seller.gstin}}</div>
          {{#if seller.pan}}<div><strong>PAN:</strong> {{seller.pan}}</div>{{/if}}
          <div style="margin-top:6px;">{{seller.line1}}{{#if seller.line2}}, {{seller.line2}}{{/if}}</div>
          <div>{{seller.city}}, {{seller.stateName}} - {{seller.pincode}}</div>
          {{#if seller.supportEmail}}<div style="margin-top:6px;">{{seller.supportEmail}}</div>{{/if}}
        </div>
      </div>

      <div class="proforma-banner">
        <strong>This is NOT a tax invoice.</strong> A proforma invoice is a quote
        confirming what {{seller.tradeName}} will charge once the buyer commits to purchase. The actual
        tax invoice (with sequential GSTIN-compliant numbering) will be issued after payment is captured.
        {{#if proformaValidUntil}}This quote is valid until <strong>{{proformaValidUntil}}</strong>.{{/if}}
      </div>

      <div class="invoice-info">
        <div class="item">
          <div class="label">Proforma No.</div>
          <div class="value mono">{{invoiceNumber}}</div>
        </div>
        <div class="item">
          <div class="label">Issued On</div>
          <div class="value">{{issuedAtFormatted}}</div>
        </div>
        <div class="item">
          <div class="label">Place of Supply</div>
          <div class="value">{{placeOfSupplyLabel}}</div>
        </div>
        <div class="item">
          <div class="label">Currency</div>
          <div class="value">{{currency}}</div>
        </div>
      </div>

      <div class="meta-grid">
        <div class="meta-block">
          <h4>Quoted To</h4>
          <div class="name">{{buyer.legalName}}</div>
          {{#if buyer.gstin}}<div class="v"><strong>GSTIN:</strong> {{buyer.gstin}}</div>{{/if}}
          {{#if buyer.email}}<div class="v">{{buyer.email}}</div>{{/if}}
          {{#if buyer.phone}}<div class="v">{{buyer.phone}}</div>{{/if}}
          {{#if buyer.line1}}<div class="v" style="margin-top:6px;">{{buyer.line1}}{{#if buyer.line2}}, {{buyer.line2}}{{/if}}</div>{{/if}}
          {{#if buyer.city}}<div class="v">{{buyer.city}}{{#if buyer.stateName}}, {{buyer.stateName}}{{/if}} {{buyer.pincode}}</div>{{/if}}
        </div>
        <div class="meta-block">
          <h4>Plan / Service</h4>
          {{#if planSnapshot.name}}<div class="v"><strong>{{planSnapshot.name}}</strong></div>{{/if}}
          {{#if order.receiptNumber}}<div class="v">Order: {{order.receiptNumber}}</div>{{/if}}
          {{#if periodLabel}}<div class="v">Period: {{periodLabel}}</div>{{/if}}
          {{#if quoteRequestId}}<div class="v">Quote Ref: <span style="font-family:'Roboto Mono',monospace;">{{quoteRequestId}}</span></div>{{/if}}
        </div>
      </div>

      <table class="lines">
        <thead>
          <tr>
            <th class="c" style="width:30px;">#</th>
            <th>Description</th>
            <th class="c">HSN/SAC</th>
            <th class="r">Qty</th>
            <th class="r">Rate</th>
            <th class="r">Taxable</th>
            <th class="r">GST</th>
            <th class="r">Total</th>
          </tr>
        </thead>
        <tbody>
          {{#each lines}}
            <tr>
              <td class="c">{{add @index 1}}</td>
              <td>{{this.description}}</td>
              <td class="c" style="font-family:'Roboto Mono',monospace;font-size:10px;">{{this.hsnSac}}</td>
              <td class="r">{{this.quantity}}</td>
              <td class="r">{{this.rateFormatted}}</td>
              <td class="r">{{this.taxableFormatted}}</td>
              <td class="r">
                {{#if this.cgstFormatted}}{{this.cgstFormatted}} + {{this.sgstFormatted}}
                {{else if this.igstFormatted}}{{this.igstFormatted}}
                {{else}}—{{/if}}
              </td>
              <td class="r"><strong>{{this.totalFormatted}}</strong></td>
            </tr>
          {{/each}}
        </tbody>
      </table>

      <div class="totals-wrap">
        <div class="totals-words">
          <div class="lbl">Amount in Words</div>
          <div style="font-style:italic; font-weight:600; color:#78350F;">{{totals.grandInWords}}</div>
        </div>
        <div class="totals">
          <div class="row"><span>Subtotal (taxable)</span><span>{{totals.taxableFormatted}}</span></div>
          {{#if totals.cgstFormatted}}<div class="row tax"><span>CGST {{totals.cgstPercent}}%</span><span>{{totals.cgstFormatted}}</span></div>{{/if}}
          {{#if totals.sgstFormatted}}<div class="row tax"><span>SGST {{totals.sgstPercent}}%</span><span>{{totals.sgstFormatted}}</span></div>{{/if}}
          {{#if totals.igstFormatted}}<div class="row tax"><span>IGST {{totals.igstPercent}}%</span><span>{{totals.igstFormatted}}</span></div>{{/if}}
          <div class="row grand"><span>Total Quoted</span><span>{{totals.grandFormatted}}</span></div>
        </div>
      </div>

      <div class="pay-instructions">
        <h5>How to pay</h5>
        Visit your billing dashboard at <strong>{{seller.website}}/billing</strong> to confirm and pay this quote.
        Once payment is captured, a GST tax invoice will be auto-issued and emailed to <strong>{{buyer.email}}</strong>.
      </div>

      <div class="footer">
        <div>
          <h5>Terms &amp; Conditions</h5>
          <p>1. This proforma is non-binding and does not establish GST liability.</p>
          <p>2. Pricing is valid for {{proformaValidityDays}} days from the issue date.</p>
          <p>3. Tax-inclusive pricing. Final invoice will reflect the actual GST applicable on the day of payment.</p>
        </div>
        <div>
          <h5>Support</h5>
          {{#if seller.supportEmail}}<p>{{seller.supportEmail}}</p>{{/if}}
          {{#if seller.supportPhone}}<p>{{seller.supportPhone}}</p>{{/if}}
          {{#if seller.website}}<p>{{seller.website}}</p>{{/if}}
        </div>
      </div>

      <div class="footer-bottom">
        <strong>{{seller.legalName}}</strong> · GSTIN {{seller.gstin}}
        {{#if seller.cin}} · CIN {{seller.cin}}{{/if}}
        <br/>
        Generated on {{generatedAt}}
      </div>
    </div>
  </body>
</html>
