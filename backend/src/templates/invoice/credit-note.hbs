<!doctype html>
<html lang="en-IN">
  <head>
    <meta charset="utf-8" />
    <title>Credit Note — {{invoiceNumber}}</title>
    <style>
      @page { size: A4; margin: 12mm 14mm; }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body {
        font-family: 'Inter', 'Segoe UI', 'Helvetica Neue', Arial, sans-serif;
        font-size: 11px;
        line-height: 1.55;
        color: #1f2937;
        background: #fff;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
      .page { max-width: 800px; margin: 0 auto; padding: 24px 32px; }

      .header {
        display: flex;
        justify-content: space-between;
        align-items: flex-start;
        gap: 24px;
        padding-bottom: 18px;
        margin-bottom: 22px;
        border-bottom: 3px solid #DC2626;
      }
      .brand { display: flex; gap: 14px; align-items: flex-start; }
      .brand-logo {
        width: 56px; height: 56px; border-radius: 8px;
        background: #fff; padding: 4px; border: 1px solid #e5e7eb;
      }
      .brand-logo img { width: 100%; height: 100%; object-fit: contain; display: block; }
      .brand-text h1 { font-size: 22px; font-weight: 800; color: #DC2626; }
      .brand-text .legal-name { font-size: 11px; color: #4b5563; font-weight: 500; }
      .brand-text .web { color: #DC2626; font-size: 10px; font-weight: 600; margin-top: 4px; }
      .seller-meta { text-align: right; font-size: 10px; color: #4b5563; }
      .seller-meta .doc-title {
        font-size: 18px; font-weight: 800; color: #DC2626;
        text-transform: uppercase; letter-spacing: 1px; margin-bottom: 6px;
      }

      .credit-banner {
        background: linear-gradient(135deg, #FEE2E2 0%, #FECACA 100%);
        border: 1px solid #F87171;
        padding: 14px 18px;
        border-radius: 8px;
        margin-bottom: 22px;
        display: flex;
        gap: 12px;
        align-items: center;
        font-size: 11px;
        color: #7F1D1D;
      }
      .credit-banner .label {
        background: #DC2626; color: #fff;
        padding: 5px 12px; border-radius: 4px;
        font-weight: 700; font-size: 10px;
        text-transform: uppercase; letter-spacing: 0.6px;
      }

      .invoice-info {
        margin-bottom: 22px;
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 10px;
      }
      .invoice-info .item {
        background: #FEF2F2; border: 1px solid #FCA5A5;
        padding: 10px 12px; border-radius: 6px;
      }
      .invoice-info .item .label {
        text-transform: uppercase; font-size: 9px;
        color: #B91C1C; letter-spacing: 0.7px;
        margin-bottom: 3px; font-weight: 600;
      }
      .invoice-info .item .value { font-size: 11px; font-weight: 700; color: #7F1D1D; }
      .invoice-info .item .value.mono { font-family: 'Roboto Mono', monospace; font-size: 10.5px; }

      .meta-grid {
        display: grid; grid-template-columns: 1fr 1fr;
        gap: 18px; margin-bottom: 22px;
      }
      .meta-block {
        background: #FAFAFA; padding: 14px 16px;
        border-radius: 8px; border: 1px solid #e5e7eb;
      }
      .meta-block h4 {
        text-transform: uppercase; font-size: 10px;
        color: #DC2626; letter-spacing: 0.7px;
        margin-bottom: 8px; font-weight: 700;
      }
      .meta-block .v { font-size: 11px; color: #1f2937; margin-bottom: 2px; }
      .meta-block .name { font-weight: 700; font-size: 12.5px; color: #111827; margin-bottom: 4px; }

      table.lines {
        width: 100%; border-collapse: collapse;
        margin-bottom: 18px;
        border-radius: 6px; overflow: hidden;
        box-shadow: 0 0 0 1px #FCA5A5;
      }
      table.lines thead th {
        background: #DC2626; color: #fff;
        padding: 10px 8px; font-size: 10px;
        text-align: left; font-weight: 600;
      }
      table.lines tbody td {
        padding: 10px 8px; font-size: 11px;
        border-bottom: 1px solid #FCA5A5;
        vertical-align: top;
      }
      table.lines tbody tr:nth-child(even) td { background: #FEF2F2; }
      table.lines td.r, table.lines th.r { text-align: right; }
      table.lines td.c, table.lines th.c { text-align: center; }
      table.lines td.desc { font-weight: 500; }
      table.lines td.hsn { font-family: 'Roboto Mono', monospace; font-size: 10px; color: #4b5563; }

      .totals { margin-left: auto; max-width: 320px; }
      .totals .row {
        display: flex; justify-content: space-between;
        padding: 5px 0; font-size: 11px;
        border-bottom: 1px dotted #FCA5A5;
      }
      .totals .row.tax { color: #B91C1C; }
      .totals .row.grand {
        border: none; border-top: 2px solid #DC2626;
        margin-top: 4px; padding: 12px 0 4px;
        font-size: 14px; font-weight: 800; color: #DC2626;
      }

      .totals-words {
        background: #FEF2F2; border: 1px dashed #FCA5A5;
        border-radius: 6px; padding: 14px 16px;
        font-size: 10.5px; color: #B91C1C; margin-bottom: 18px;
      }
      .totals-words .lbl {
        text-transform: uppercase; font-size: 9px;
        color: #DC2626; font-weight: 700;
        letter-spacing: 0.7px; margin-bottom: 4px;
      }
      .totals-words .val { font-size: 11px; color: #7F1D1D; font-weight: 600; font-style: italic; }

      .footer {
        margin-top: 26px; padding-top: 18px;
        border-top: 1px solid #e5e7eb;
        display: grid; grid-template-columns: 1fr 1fr; gap: 20px;
        font-size: 10px; color: #4b5563;
      }
      .footer h5 {
        text-transform: uppercase; font-size: 10px;
        color: #111827; margin-bottom: 6px;
        letter-spacing: 0.6px; font-weight: 700;
      }
      .footer-bottom {
        margin-top: 18px; padding-top: 12px;
        border-top: 1px dashed #e5e7eb;
        text-align: center; font-size: 9px; color: #9ca3af;
      }
      .footer-bottom strong { color: #4b5563; }
    </style>
  </head>
  <body>
    <div class="page">
      <div class="header">
        <div class="brand">
          {{#if seller.logoUrl}}<div class="brand-logo"><img src="{{seller.logoUrl}}" alt="{{seller.tradeName}}" /></div>{{/if}}
          <div class="brand-text">
            <h1>{{seller.tradeName}}</h1>
            <div class="legal-name">A unit of {{seller.legalName}}</div>
            {{#if seller.website}}<div class="web">{{seller.website}}</div>{{/if}}
          </div>
        </div>
        <div class="seller-meta">
          <div class="doc-title">Credit Note</div>
          <div><strong>GSTIN:</strong> {{seller.gstin}}</div>
          {{#if seller.pan}}<div><strong>PAN:</strong> {{seller.pan}}</div>{{/if}}
          <div style="margin-top:6px;">{{seller.line1}}{{#if seller.line2}}, {{seller.line2}}{{/if}}</div>
          <div>{{seller.city}}, {{seller.stateName}} - {{seller.pincode}}</div>
          {{#if seller.supportEmail}}<div style="margin-top:6px;"><strong>Email:</strong> {{seller.supportEmail}}</div>{{/if}}
          {{#if seller.supportPhone}}<div><strong>Phone:</strong> {{seller.supportPhone}}</div>{{/if}}
        </div>
      </div>

      <div class="credit-banner">
        <span class="label">Credit Note</span>
        <div>
          This document credits <strong>{{totals.grandFormatted}}</strong> back to the buyer
          {{#if relatedInvoiceNumber}}against original invoice <strong>{{relatedInvoiceNumber}}</strong>{{/if}}.
          Use it to claim a reverse input-tax-credit if the original purchase
          was made for business use.
        </div>
      </div>

      <div class="invoice-info">
        <div class="item">
          <div class="label">Credit Note No.</div>
          <div class="value mono">{{invoiceNumber}}</div>
        </div>
        <div class="item">
          <div class="label">Issued On</div>
          <div class="value">{{issuedAtFormatted}}</div>
        </div>
        <div class="item">
          <div class="label">Place of Supply</div>
          <div class="value">{{placeOfSupplyLabel}}</div>
        </div>
        <div class="item">
          <div class="label">Reason</div>
          <div class="value">{{creditReason}}</div>
        </div>
      </div>

      <div class="meta-grid">
        <div class="meta-block">
          <h4>Credit To</h4>
          <div class="name">{{buyer.legalName}}</div>
          {{#if buyer.gstin}}<div class="v"><strong>GSTIN:</strong> {{buyer.gstin}}</div>{{/if}}
          {{#if buyer.email}}<div class="v">{{buyer.email}}</div>{{/if}}
          {{#if buyer.line1}}<div class="v" style="margin-top:6px;">{{buyer.line1}}{{#if buyer.line2}}, {{buyer.line2}}{{/if}}</div>{{/if}}
          {{#if buyer.city}}<div class="v">{{buyer.city}}{{#if buyer.stateName}}, {{buyer.stateName}}{{/if}} {{buyer.pincode}}</div>{{/if}}
        </div>
        <div class="meta-block">
          <h4>Reference</h4>
          {{#if relatedInvoiceNumber}}<div class="v"><strong>Original Invoice:</strong> {{relatedInvoiceNumber}}</div>{{/if}}
          {{#if order.receiptNumber}}<div class="v"><strong>Order:</strong> {{order.receiptNumber}}</div>{{/if}}
          {{#if refundId}}<div class="v"><strong>Refund ID:</strong> <span style="font-family:'Roboto Mono',monospace;">{{refundId}}</span></div>{{/if}}
          {{#if subscription.id}}<div class="v"><strong>Subscription:</strong> {{subscription.id}}</div>{{/if}}
        </div>
      </div>

      <table class="lines">
        <thead>
          <tr>
            <th class="c" style="width:30px;">#</th>
            <th>Description</th>
            <th class="c">HSN/SAC</th>
            <th class="r">Qty</th>
            <th class="r">Rate</th>
            <th class="r">Taxable</th>
            <th class="r">CGST</th>
            <th class="r">SGST</th>
            <th class="r">IGST</th>
            <th class="r">Total</th>
          </tr>
        </thead>
        <tbody>
          {{#each lines}}
            <tr>
              <td class="c">{{add @index 1}}</td>
              <td class="desc">{{this.description}}</td>
              <td class="hsn c">{{this.hsnSac}}</td>
              <td class="r">{{this.quantity}}</td>
              <td class="r">{{this.rateFormatted}}</td>
              <td class="r">{{this.taxableFormatted}}</td>
              <td class="r">{{#if this.cgstFormatted}}{{this.cgstFormatted}}{{else}}—{{/if}}</td>
              <td class="r">{{#if this.sgstFormatted}}{{this.sgstFormatted}}{{else}}—{{/if}}</td>
              <td class="r">{{#if this.igstFormatted}}{{this.igstFormatted}}{{else}}—{{/if}}</td>
              <td class="r"><strong>{{this.totalFormatted}}</strong></td>
            </tr>
          {{/each}}
        </tbody>
      </table>

      <div class="totals-words">
        <div class="lbl">Credit Amount in Words</div>
        <div class="val">{{totals.grandInWords}}</div>
      </div>

      <div class="totals">
        <div class="row"><span>Subtotal (taxable)</span><span>{{totals.taxableFormatted}}</span></div>
        {{#if totals.cgstFormatted}}<div class="row tax"><span>CGST {{totals.cgstPercent}}%</span><span>{{totals.cgstFormatted}}</span></div>{{/if}}
        {{#if totals.sgstFormatted}}<div class="row tax"><span>SGST {{totals.sgstPercent}}%</span><span>{{totals.sgstFormatted}}</span></div>{{/if}}
        {{#if totals.igstFormatted}}<div class="row tax"><span>IGST {{totals.igstPercent}}%</span><span>{{totals.igstFormatted}}</span></div>{{/if}}
        <div class="row grand"><span>Total Credit</span><span>{{totals.grandFormatted}}</span></div>
      </div>

      <div class="footer">
        <div>
          <h5>Notes</h5>
          <p>1. Credit notes adjust the GST liability of the original invoice. Reverse the input-tax-credit claimed previously.</p>
          <p>2. Refund amount will reflect in your account in 5–7 business days from the original payment method.</p>
          <p>3. This is a system-generated credit note — no signature required.</p>
        </div>
        <div>
          <h5>Settlement &amp; Support</h5>
          <p>Refund processed via Razorpay to the original payment method.</p>
          {{#if seller.supportEmail}}<p style="margin-top:6px;">{{seller.supportEmail}}</p>{{/if}}
          {{#if seller.supportPhone}}<p>{{seller.supportPhone}}</p>{{/if}}
          {{#if seller.website}}<p>{{seller.website}}</p>{{/if}}
        </div>
      </div>

      <div class="footer-bottom">
        <strong>{{seller.legalName}}</strong> · GSTIN {{seller.gstin}}
        {{#if seller.cin}} · CIN {{seller.cin}}{{/if}}
        {{#if seller.pan}} · PAN {{seller.pan}}{{/if}}
        <br/>
        Generated on {{generatedAt}} · Credit Note retained for {{retentionYears}} years per GST Act §36
      </div>
    </div>
  </body>
</html>
