// --- Employer team / multi-seat (CV Enterprise feature.multi_seat) ---

enum TeamRole {
  OWNER
  ADMIN
  RECRUITER
}

enum TeamMemberStatus {
  PENDING
  ACTIVE
  REVOKED
  EXPIRED
}

model EmployerTeamMember {
  id              String           @id @default(uuid())
  companyId       String
  userId          String?          // null until invite is accepted
  invitedEmail    String
  role            TeamRole         @default(RECRUITER)
  status          TeamMemberStatus @default(PENDING)
