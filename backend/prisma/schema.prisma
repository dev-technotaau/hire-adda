// --- Saved Searches ---

model SavedSearch {
  id         String   @id @default(uuid())
  userId     String
  name       String
  searchType String // "CANDIDATE_SEARCH" or "JOB_SEARCH"
  filters    Json
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, searchType])
}

// ─────────────────────────────────────────────────────────────────────
// Search history — distinct from SavedSearch in that it auto-records
// every search the user (or guest) runs, supports a "new jobs since
// last seen" delta count for chip badges, and dedups by deterministic
// `filtersHash`.
//
// Powers the homepage hero chips, the listing-page chip strip, and
// the candidate dashboard "recent searches" widget.
// ─────────────────────────────────────────────────────────────────────
enum SearchHistoryType {
  JOB
  CANDIDATE
  COMPANY
}

// ─────────────────────────────────────────────────────────────────────
// Curated listings — drive the public-search header mega-menu, footer
// mega-section, and SEO landing pages (`/jobs/category/it-software`,
// `/jobs/in/delhi`, etc.). Editable via super-admin (out-of-scope for
// this delivery — model is ready). Seeded with ~150 entries on first
// deploy via `scripts/seed-curated-listings.ts`.
// ─────────────────────────────────────────────────────────────────────
enum CuratedType {
  JOB_CATEGORY        // "IT Jobs", "Sales Jobs"
  JOB_DEMAND          // "Fresher Jobs", "Remote Jobs"
  JOB_LOCATION        // "Jobs in Delhi"
  JOB_QUALIFICATION   // "10th Pass Jobs", "BTech Jobs"
  JOB_DEPARTMENT      // "Engineering Jobs", "Operations Jobs"
  JOB_COLLECTION      // "Top Companies Hiring", "Trending Now"
  COMPANY_CATEGORY    // "Unicorn", "MNC", "Startup"
  COMPANY_COLLECTION  // "Top Companies", "IT Companies"
}

model CuratedListing {
  id              String      @id @default(uuid())
  slug            String      @unique
  type            CuratedType
  label           String
  // Filter preset applied to the search backend when this slug is
  // visited. Shape mirrors the search-API filter blob for drop-in
  // application.
  filterPreset    Json
  iconKey         String?
  displayOrder    Int         @default(0)
  isFeatured      Boolean     @default(false)
  metaTitle       String?
  metaDescription String?
  heroH1          String?
  heroSubtitle    String?
  isPublic        Boolean     @default(true)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  @@index([type, isPublic, displayOrder])
  @@index([slug])
}

// --- Company Follow (candidates following companies) ---
//
// One row per (candidate, company) pair. Candidates browse the public
// company directory and click "Follow"; employers see follower counts
// + a list of their followers in the dashboard.
//
// Fan-out notifications (new job from a followed company) read this
// table via the BullMQ follower-notify worker.
model CompanyFollow {
  id        String   @id @default(uuid())
  /** The candidate who's following. */
  userId    String
  /** The CompanyProfile being followed (NOT the employer userId — the
      profile id, so we can join cleanly to JobPost.companyId). */
  companyId String
  createdAt DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  company CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([userId, createdAt])
  @@index([companyId, createdAt])
}

model SearchHistory {
  id           String            @id @default(uuid())
  // Either userId (auth) or sessionId (guest) is set; never both null.
  userId       String?
  sessionId    String?
  searchType   SearchHistoryType
  // Canonical filter blob, sorted + normalised so equivalent searches
  // share the same hash regardless of input ordering.
  filters      Json
  // SHA-256 of the canonical JSON; used for the (user/session, type, hash)
  // unique tuple so re-running the same search increments `hits` instead
  // of inserting a duplicate row.
  filtersHash  String
  query        String?
  location     String?
  resultsCount Int               @default(0)
  // When the user last actually ran or viewed this search. Used to
  // compute "new jobs since" deltas — counts JobPost.createdAt > lastSeenAt.
  lastSeenAt   DateTime          @default(now())
  hits         Int               @default(1)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, searchType, filtersHash], name: "user_unique_search")
  @@unique([sessionId, searchType, filtersHash], name: "session_unique_search")
  @@index([userId, lastSeenAt])
  @@index([sessionId, lastSeenAt])
  @@index([searchType, lastSeenAt])
}

// --- Profile Views ---

model ProfileView {
  id            String   @id @default(uuid())
  viewerId      String
  profileUserId String
  viewType      String // "CANDIDATE_PROFILE" or "COMPANY_PROFILE"
  createdAt     DateTime @default(now())

  viewer      User @relation("ProfileViewer", fields: [viewerId], references: [id], onDelete: Cascade)
  profileUser User @relation("ProfileViewed", fields: [profileUserId], references: [id], onDelete: Cascade)

  @@index([profileUserId, createdAt])
  @@index([viewerId])
}

// --- Notification System ---

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  category  String? // e.g., "job_match", "application_update", "security"
  link      String? // Deep link to relevant page
  isRead    Boolean          @default(false)
  readAt    DateTime?
  metadata  Json? // Extra structured data
  createdAt DateTime         @default(now())
  updatedAt DateTime         @default(now()) @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, isRead, createdAt])
  @@index([userId, createdAt])
  @@index([createdAt])
}

// --- Form Drafts ---

enum FormDraftType {
  CANDIDATE_PROFILE
  JOB_SEARCH_PREFERENCES
  CANDIDATE_SEARCH
  JOB_POSTING
  EMPLOYER_PROFILE
}

model FormDraft {
