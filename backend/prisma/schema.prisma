  JOB_DAYS_LIVE
  APPLICATIONS
  CV_UNLOCK
  SEARCH_RESULT
  MATCHED_PROFILE_EMAIL
  FEATURE_FLAG
  SEAT
  BOOST_DAYS
  VENDOR_LEAD
  CUSTOM
}

enum PlanFeatureKind {
