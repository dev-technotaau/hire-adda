// --- Models ---

model CandidateProfile {
  id     String @id @default(uuid())
  userId String @unique

  // Personal Details
  headline           String? // Professional headline ("Senior Java Dev | 8 yrs exp")
  pronouns           String? // e.g., "he/him", "she/her", "they/them"
  gender             Gender?
  dob                DateTime?
  maritalStatus      MaritalStatus?
  nationality        String?              @default("Indian")
  hometown           String?
  category           ReservationCategory? // Indian reservation: GENERAL, SC, ST, OBC, EWS
  bio                String?
  resume             String? // URL to file (Cloudinary/R2)
  resumeOriginalName String?
  resumeSize         Int? // File size in bytes
  resumeMimeType     String? // MIME type (application/pdf, etc.)
  resumeUploadedAt   DateTime? // Exact timestamp of resume upload
  additionalResumes  Json? // Array of { name, url, originalName?, isDefault?, uploadedAt? }
  generatedResumeUrl String? // URL to last generated resume (R2)
  generatedResumeAt  DateTime? // When the resume was last generated
  videoResumeUrl     String? // URL to video resume
  profileImage       String? // Cloudinary URL
  imageVariants      Json? // { thumbnail, small, medium, original } URLs

  // Structured Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  pincode      String?
  country      String? @default("India")

  // Contact & Location
  currentLocation    String?
  preferredLocations String[]
  phone              String?
  alternatePhone     String?
  alternateEmail     String?

  // Geo Coordinates (auto-populated by geocoding worker)
  latitude  Float?
  longitude Float?

  // Professional
  experienceYears       Float             @default(0)
  totalExperienceMonths Int? // More precise than Float years
  experienceLevel       ExperienceLevel? // FRESHER through EXECUTIVE (matches JobPost.experienceLevel)
  currentCompany        String?
  currentRole           String?
  currentIndustry       String?
  currentDepartment     String?
  functionalArea        String?
  currSalary            Decimal?          @db.Decimal(12, 2)
  expectedSalaryMin     Decimal?          @db.Decimal(12, 2)
  expectedSalaryMax     Decimal?          @db.Decimal(12, 2)
  salaryCurrency        String            @default("INR")
  noticePeriod          NoticePeriod?
  servingNoticePeriod   Boolean           @default(false)
  workStatus            WorkStatus?       @default(ACTIVELY_LOOKING)
  hasCareerBreak        Boolean           @default(false)
  careerBreakType       CareerBreakType?
  careerBreakReason     String?
  openToWork            OpenToWorkStatus?

  // Career Preferences
  preferredJobType         JobType[]  @default([])
  preferredWorkMode        WorkMode[] @default([])
  preferredShift           ShiftType?
  preferredIndustries      String[]   @default([])
  preferredRoleCategories  String[]   @default([])
  dateOfAvailability       DateTime?
  willingToRelocate        Boolean?   @default(false)
  travelWillingnessPercent Int?       @default(0)

  // Education Summary (matches JobPost education filters)
  highestEducationLevel EducationLevel? // Matches JobPost.educationRequired
  highestDegree         SpecificDegree? // Matches JobPost.specificDegrees

  // Visa, Work Authorization & Documents
  visaStatus         String?
  workPermitStatus   String?
  passportNumber     String?
  passportExpiryDate DateTime?
  hasDrivingLicense  Boolean             @default(false)
  drivingLicenseType DrivingLicenseType? @default(NONE) // Matches JobPost.drivingLicenseRequired
  ownVehicle         Boolean             @default(false)
  vehicleTypes       VehicleType[]       @default([])
  isVeteran          Boolean             @default(false)
  blockedCompanies   String[]            @default([])

  // Skills & Education (JSON for flexibility)
  skills                  String[]
  languages               String[]
  itSkills                Json? // Array of { technology, version?, lastUsed?, experienceYears?, proficiency? }
  education               Json? // Array of { institution, degree, field, startDate, endDate?, grade?, gradeType?, courseType?, specialization?, description?, activities? }
  experience              Json? // Array of { company, role, location?, industry?, department?, employmentType?, startDate, endDate?, isCurrent?, description?, keyAchievements[]?, teamSize?, reportingTo?, annualCtc? }
  certifications          Json? // Array of { name, issuer, issueDate?, expiryDate?, credentialId?, url?, doesNotExpire? }
  projects                Json? // Array of { name, description?, url?, startDate?, endDate?, technologies[]?, role?, teamSize?, client?, isCurrent? }
  publications            Json? // Array of { title, publisher?, publicationDate?, url?, description?, authors? }
  patents                 Json? // Array of { title, patentOffice?, patentNumber?, status?, filingDate?, issueDate?, url?, description?, inventors? }
  awards                  Json? // Array of { title, issuer?, date?, description? }
  volunteerExperience     Json? // Array of { organization, role, cause?, startDate?, endDate?, isCurrent?, description? }
  professionalMemberships Json? // Array of { organization, role?, startDate?, endDate?, membershipId?, description? }
  courses                 Json? // Array of { name, provider?, completionDate?, url?, associatedWith? }
  testScores              Json? // Array of { testName, score, dateOfExam?, associatedWith?, description? }
  references              Json? // Array of { name, designation?, organization?, email?, phone?, relationship? }
  languageProficiency     Json? // Array of { language, proficiency: BASIC|INTERMEDIATE|FLUENT|NATIVE, readWrite? }
  skillsWithProficiency   Json? // Array of { skill, proficiency: BEGINNER|INTERMEDIATE|ADVANCED|EXPERT, yearsOfExperience? }

  // Interests
  interests String[] @default([])
  hobbies   String[] @default([])

  // Disability Details
  isPhysicallyChallenged Boolean         @default(false)
  disabilityType         DisabilityType? @default(NONE)
  disabilityPercentage   Int?

  // Social & Online Profiles
  githubProfile        String?
  linkedinProfile      String?
  portfolioUrl         String?
  stackOverflowProfile String?
  twitterProfile       String?
  personalBlogUrl      String?
  dribbbleProfile      String?
  behanceProfile       String?
  mediumProfile        String?
  youtubeChannel       String?

  // AI-parsed resume data (from Document AI)
  parsedResumeData Json?

  // Notification Preferences
  notificationPreferences Json? // { emailNotifications, smsNotifications, whatsappNotifications, inAppNotifications, fcmNotifications, webPushNotifications }

  // Cached scores
  profileCompleteness Int @default(0) // 0-100 percentage

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  applications JobApplication[]

  @@index([userId])
  @@index([currentLocation])
  @@index([experienceYears])
  @@index([workStatus])
  @@index([noticePeriod])
  @@index([currentIndustry])
  @@index([willingToRelocate])
  @@index([openToWork])
  @@index([city, state])
  @@index([latitude, longitude])
  @@index([workStatus, noticePeriod, experienceYears])
  @@index([experienceLevel])
  @@index([highestEducationLevel])
  @@index([functionalArea])
  @@index([profileCompleteness])
  @@index([highestDegree])
  @@index([drivingLicenseType])
}

model CompanyProfile {
  id     String @id @default(uuid())
  userId String @unique

  // SEO + public-search slug. Generated from companyName via
  // buildCompanySlug() with collision suffixing (-2, -3, ...). Used in
  // the canonical /companies/{slug} URL.
  slug             String?  @unique
  // Employer can opt out of the public CV-database / company-directory
  // surfaces per row. Defaults to true so existing public-by-default
  // semantics are preserved.
  publicSearchable Boolean  @default(true)

  // Account Classification
  accountType     AccountType? // COMPANY or INDIVIDUAL
  hiringType      HiringType?  // DIRECT (own company) or CONSULTANCY (staffing agency)

  // Company Details
  companyName     String
  companyType     CompanyType? // PRIVATE, PUBLIC, STARTUP, MNC, GOVERNMENT, etc.
  tagline         String?
  logo            String? // Cloudinary URL
  logoVariants    Json? // { thumbnail, small, medium, original } URLs
  coverImage      String? // Banner image (Cloudinary URL)
  coverVariants   Json? // { thumbnail, small, medium, original } URLs
  companyVideoUrl String? // Company intro/culture video URL
  industry        String?
  subIndustry     String? // e.g., "SaaS", "Payments", "Cloud Infrastructure"
  specialties     String[]     @default([])
  companySize     String? // e.g., "1-10", "11-50"
  employeeCount   Int? // Approximate exact count
  numberOfOffices Int? // Total number of office locations
  description     String?
  whyWorkForUs    String? // Employer pitch / "Why Work For Us" section
  website         String?
  careersPageUrl  String? // Company careers page
  blogUrl         String? // Company blog
  foundedYear     Int?
  parentCompany   String? // Parent/holding company
  stockTicker     String? // Stock exchange ticker symbol

  // Registration & Verification
  gstNumber  String? @unique
  cinNumber  String? @unique // Corporate Identity Number (India)
  panNumber  String?
  isVerified Boolean @default(false)

  // Financial & Funding
  annualRevenueRange String? // e.g., "1-5 Cr", "100-500 Cr"
  fundingStage       FundingStage?
  totalFundingRaised String? // e.g., "$50M", "₹200 Cr"
  investors          String[]      @default([])

  // Products & Tech
  productsServices String[] @default([])
  techStack        String[] @default([])

  // Culture & Benefits
  companyCulture         String?
  missionStatement       String?
  visionStatement        String?
  coreValues             String[] @default([])
  diversityStatement     String?
  employeeResourceGroups String[] @default([])
  csrInitiatives         String? // CSR / social impact description
  benefits               String[] @default([])
  structuredPerks        Json? // Array of { category, perks[] }
  workplacePolicies      Json? // Array of { title, description }
  interviewProcess       String? // Description of interview/hiring process
  awardsRecognitions     Json? // Array of { title, year?, issuingOrg?, description? }
  leadershipTeam         Json? // Array of { name, designation, linkedinUrl?, imageUrl?, bio? }
  employeeTestimonials   Json? // Array of { name, designation?, department?, quote, imageUrl? }
  officePhotos           Json? // Array of { url, caption?, location? }
  socialLinks            Json? // { linkedin, twitter, facebook, instagram, youtube, glassdoor }

  // Contact
  contactEmail             String?
  contactPhone             String?
  contactPersonName        String?
  contactPersonDesignation String?

  // Notification Preferences
  notificationPreferences Json? // { emailApplications, emailMessages, emailMarketing, smsAlerts, whatsappNotifications, inAppNotifications, fcmNotifications, webPushNotifications, weeklyDigest }

  // Structured Address
  addressLine1 String?
  addressLine2 String?
  city         String?
  state        String?
  pincode      String?
  country      String? @default("India")

  // Location
  headquarters String?
  locations    String[]

  // Geo Coordinates (auto-populated by geocoding worker)
  latitude  Float?
  longitude Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Default billing address — pointer into BillingAddress (per plan §2.3).
  // Used by checkout to pre-fill the buyer's GST/legal name + place-of-supply.
  // Optional: many companies start without a billing address until first paid order.
  defaultBillingAddressId String?

  user                  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  jobs                  JobPost[]
  jobTemplates          JobTemplate[]
  defaultBillingAddress BillingAddress?  @relation("CompanyDefaultBillingAddress", fields: [defaultBillingAddressId], references: [id], onDelete: SetNull)
  teamMembers           EmployerTeamMember[] @relation("CompanyTeamMembers")
  followers             CompanyFollow[]
  reviews               CompanyReview[]
  reviewAggregate       CompanyReviewAggregate?

  @@index([userId])
  @@index([companyName])
  @@index([companyType])
  @@index([industry])
  @@index([fundingStage])
  @@index([city, state])
  @@index([latitude, longitude])
  @@index([defaultBillingAddressId])
  @@index([slug])
  @@index([publicSearchable, isVerified])
}

model JobPost {
  id        String @id @default(uuid())
  companyId String

  // SEO + public-search slug. Generated from
  // {title-kebab}-{company-or-city-kebab}-{shortid8} via buildJobSlug().
  // Used in the canonical /jobs/{slug} URL.
  slug             String?  @unique
  // Employer can opt out of the public job-board surface per job
  // (e.g. confidential search). When false, the job is still visible
  // to invited candidates but excluded from /jobs and search engines.
  publicSearchable Boolean  @default(true)

  // Consultancy / Staffing — the actual client company this job is for
  clientCompanyName String?

  // Job Details
  title               String
  description         String
  keyResponsibilities String? // Separate from description (Naukri-style)
  requirements        String? // Rich text or raw text
  benefits            String?

  // Metadata
  type      JobType    @default(FULL_TIME)
  status    JobStatus  @default(OPEN)
  workMode  WorkMode?  @default(ON_SITE) // ON_SITE, REMOTE, HYBRID
  shiftType ShiftType? // DAY, NIGHT, ROTATIONAL, FLEXIBLE

  // Classification
  industry       String?
  department     String?
  roleCategory   String?
  functionalArea FunctionalArea?

  // Experience & Education
  experienceMin           Int              @default(0)
  experienceMax           Int?
  experienceLevel         ExperienceLevel? // FRESHER through EXECUTIVE
  educationRequired       EducationLevel? // Minimum education level
  preferredEducationField String?
  ugRequired              EducationLevel?
  pgRequired              EducationLevel?
  specificDegrees         SpecificDegree[] @default([])
  degreeSpecializations   String[]         @default([])

  // Compensation & Location
  location         String
  latitude         Float?
  longitude        Float?
  isRemote         Boolean     @default(false) // Kept for backward compat
  salaryMin        Decimal?    @db.Decimal(12, 2)
  salaryMax        Decimal?    @db.Decimal(12, 2)
  currency         String      @default("INR")
  salaryType       SalaryType? @default(ANNUAL) // ANNUAL, MONTHLY, HOURLY
  salaryDisclosed  Boolean     @default(true)
  salaryNegotiable Boolean     @default(false)

  // Skills
  skillsRequired         String[]
  niceToHaveSkills       String[]                 @default([])
  certificationsRequired String[]                 @default([])
  languagesRequired      Json? // Array of { language, proficiency }
  noticePeriodPreference NoticePeriodPreference[] @default([])

  // Vacancy & Urgency
  numberOfOpenings Int?          @default(1)
  urgencyLevel     UrgencyLevel? @default(NORMAL)
  isFeatured       Boolean       @default(false)
  isPremium        Boolean       @default(false)
  isConfidential   Boolean       @default(false)
  referenceCode    String?

  // Content & SEO
  tags     String[] @default([])
  jobPerks String[] @default([])

  // Travel & Relocation
  travelRequirementPercent Int?     @default(0)
  relocationAssistance     Boolean  @default(false)
  additionalLocations      String[] @default([])
  accommodationProvided    Boolean  @default(false)

  // Application & Interview
  applicationDeadline DateTime?
  interviewProcess    String?
  isWalkIn            Boolean   @default(false)
  walkInDetails       Json? // { date, time, venue, contactPerson, contactPhone }
  contactPerson       String?
  contactEmail        String?

  // Walk-in structured fields
  walkInStartDate     DateTime?
  walkInEndDate       DateTime?
  walkInTime          String?
  walkInVenue         String?
  walkInContactPerson String?
  walkInContactPhone  String?
  walkInInstructions  String?

  // Diversity & Inclusion
  diversityTags String[] @default([])

  // Compliance & Requirements
  visaSponsorshipAvailable Boolean             @default(false)
  backgroundCheckRequired  Boolean             @default(false)
  isPwdFriendly            Boolean             @default(false)
  passportRequired         Boolean             @default(false)
  bondDetails              String?
  drivingLicenseRequired   DrivingLicenseType?

  // Age & Gender (India-specific)
  ageMin           Int?
  ageMax           Int?
  genderPreference GenderPreference? @default(ANY)

  // Posting Control
  postingVisibility  PostingVisibility @default(PUBLIC)
  applyMethod        ApplyMethod       @default(IN_PLATFORM)
  externalApplyUrl   String?
  scheduledPublishAt DateTime?

  // Relations for screening
  screeningQuestions ScreeningQuestion[]

  // Stats
  views Int @default(0)

  // Lifecycle
  closedReason String? // "EXPIRED", "FILLED", "CANCELLED"
  closedAt               DateTime?
  expiresAt              DateTime?
  lastExpirationWarning  DateTime? // Last time an expiration warning was sent
  createdAt              DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  company      CompanyProfile            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  applications    JobApplication[]
  savedBy         SavedJob[]
  dismissedBy     DismissedRecommendation[]
  candidateMatches JobCandidateMatch[]
  vendorLeads     VendorLead[]
  assistedHiringRequests AssistedHiringRequest[] @relation("AssistedHiringJob")

  @@index([companyId])
  @@index([status])
  @@index([title])
  @@index([location])
  @@index([companyId, status])
  @@index([companyId, createdAt])
  @@index([status, createdAt])
  @@index([industry])
  @@index([expiresAt])
  @@index([workMode])
  @@index([shiftType])
  @@index([experienceLevel])
  @@index([educationRequired])
  @@index([urgencyLevel])
  @@index([isFeatured])
  @@index([applicationDeadline])
  @@index([status, workMode])
  @@index([status, experienceLevel])
  @@index([status, expiresAt])
  @@index([latitude, longitude])
  @@index([functionalArea])
  @@index([postingVisibility])
  @@index([scheduledPublishAt])
  @@index([isConfidential])
  @@index([referenceCode])
  @@index([type])
  @@index([status, type])
  @@index([slug])
  @@index([publicSearchable, status])
}

model JobApplication {
  id          String @id @default(uuid())
  jobId       String
  candidateId String

  status         ApplicationStatus @default(APPLIED)
  coverLetter    String?
  resumeSnapshot String? // Link to resume at time of application

  // Match & Source
  matchScore     Float? // Pre-computed match score at apply time
  source         String? // "SEARCH", "RECOMMENDATION", "DIRECT", "WALK_IN", "REFERRAL"
  candidateNotes String? // Candidate's own notes about the application

  // Interview & Decision
  interviewDate     DateTime?
  interviewNotes    String?
  interviewFeedback Json? // Array of { stage, interviewer?, rating?, feedback?, date? }
  rejectionReason   String?
  viewedAt          DateTime? // When employer first viewed
  selectedAt        DateTime? // When employer selected candidate

  // Offer & Hiring
  offerDetails Json? // { salary, joiningDate, designation, location }
  offeredAt    DateTime?
  hiredAt      DateTime?

  appliedAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
  reviewReminderSentAt  DateTime? // Prevents duplicate review reminders

  job              JobPost           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate        CandidateProfile  @relation(fields: [candidateId], references: [id], onDelete: Cascade)
  screeningAnswers ScreeningAnswer[]

  @@unique([jobId, candidateId]) // Prevent duplicate applications
  @@index([jobId])
  @@index([candidateId])
  @@index([status])
  @@index([jobId, status])
  @@index([candidateId, status])
  @@index([source])
  @@index([offeredAt])
  @@index([hiredAt])
}

model ScreeningQuestion {
  id            String                @id @default(uuid())
  jobId         String
  question      String
  questionType  ScreeningQuestionType @default(TEXT)
  isRequired    Boolean               @default(false)
  isDealBreaker Boolean               @default(false)
  options       Json?
  idealAnswer   String?
  displayOrder  Int                   @default(0)
  createdAt     DateTime              @default(now())

  job     JobPost           @relation(fields: [jobId], references: [id], onDelete: Cascade)
  answers ScreeningAnswer[]

  @@index([jobId])
  @@index([jobId, displayOrder])
}

model ScreeningAnswer {
  id            String   @id @default(uuid())
  applicationId String
  questionId    String
  answer        String
  createdAt     DateTime @default(now())

  application JobApplication    @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  question    ScreeningQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([applicationId, questionId])
  @@index([applicationId])
  @@index([questionId])
}

model JobTemplate {
  id           String   @id @default(uuid())
  companyId    String
  name         String
  description  String?
  templateData Json
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company CompanyProfile @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([companyId, name])
}

model VerificationRequest {
  id     String @id @default(uuid())
  userId String

  type   VerificationType
  status VerificationStatus @default(PENDING)

  // Data
  documentUrl String? // R2/Cloudinary URL
  data        Json? // Extra data (e.g., entered GST number)

  // Admin logic
  reviewedBy    String?
  adminComments String?
  reviewedAt    DateTime?

  // Escalation
  escalatedAt      DateTime?
  escalatedBy      String?
  escalationReason String?
  priority         String?   @default("NORMAL") // NORMAL, HIGH, URGENT

  // SLA & Approval Chain
  slaDeadline          DateTime?
  approvalChain        Json? // Array of { level, approverId, approvedAt?, comments? }
  currentApprovalLevel Int?      @default(1)
  autoEscalated        Boolean   @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User  @relation("UserVerifications", fields: [userId], references: [id], onDelete: Cascade)
  reviewer User? @relation("AdminReviews", fields: [reviewedBy], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([status])
  @@index([type])
  @@index([type, status])
  @@index([priority])
}

model SavedJob {
  id     String @id @default(uuid())
  userId String
  jobId  String

  createdAt DateTime @default(now())

  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  JobPost @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
}

// --- Saved Candidates (Employer bookmarks candidates) ---

model SavedCandidate {
  id          String   @id @default(uuid())
  employerId  String
  candidateId String
  notes       String?
  savedAt     DateTime @default(now())

  employer  User @relation("EmployerSavedCandidates", fields: [employerId], references: [id], onDelete: Cascade)
  candidate User @relation("CandidateSavedBy", fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([employerId, candidateId])
  @@index([employerId])
  @@index([candidateId])
