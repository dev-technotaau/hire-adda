  userId    String
  formType  FormDraftType
  data      Json // The draft form data
  name      String? // Optional user-given name for the draft
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, formType, name])
  @@index([userId, formType])
}

// --- Push Subscriptions (Web Push VAPID) ---

model PushSubscription {
  id        String   @id @default(uuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// --- Device Tokens (FCM) ---

model DeviceToken {
  id         String   @id @default(uuid())
  userId     String
  token      String   @unique
  platform   String? // "android", "ios", "web"
  deviceName String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// --- Job-Candidate Match Notifications (Tracking multi-channel notifications) ---

model JobCandidateMatch {
  id                String    @id @default(uuid())
  jobId             String
  candidateId       String
  matchScore        Float?
  notificationsSent Boolean   @default(false)
  emailSent         Boolean   @default(false)
  smsSent           Boolean   @default(false)
  pushSent          Boolean   @default(false)
  whatsappSent      Boolean   @default(false)
  createdAt         DateTime  @default(now())
  notifiedAt        DateTime?

  job       JobPost @relation(fields: [jobId], references: [id], onDelete: Cascade)
  candidate User    @relation("CandidateMatches", fields: [candidateId], references: [id], onDelete: Cascade)

  @@unique([jobId, candidateId])
  @@index([jobId])
  @@index([candidateId])
  @@index([notificationsSent])
  @@index([createdAt])
}

// --- System Configuration ---

model SystemConfig {
  id        String   @id @default(uuid())
  key       String   @unique
  value     Json
  updatedBy String?
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// --- WebAuthn Credentials (Passkeys) ---

model WebAuthnCredential {
  id           String   @id @default(cuid())
  userId       String
  credentialId String   @unique
  publicKey    Bytes
  counter      BigInt   @default(0)
  transports   String[]
  deviceType   String?
  backedUp     Boolean  @default(false)
  friendlyName String?
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// --- Webhook Endpoints ---

model WebhookEndpoint {
  id              String    @id @default(cuid())
  userId          String
  url             String
  secret          String
  events          String[]
  isActive        Boolean   @default(true)
  description     String?
  failureCount    Int       @default(0)
  lastTriggeredAt DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveries WebhookDelivery[]

  @@index([userId])
  @@index([isActive])
}

// --- Webhook Deliveries ---

model WebhookDelivery {
  id         String   @id @default(cuid())
  webhookId  String
  event      String
  payload    Json
  statusCode Int?
  response   String?
  success    Boolean  @default(false)
  attempt    Int      @default(1)
  error      String?
  createdAt  DateTime @default(now())

  webhook WebhookEndpoint @relation(fields: [webhookId], references: [id], onDelete: Cascade)

  @@index([webhookId])
  @@index([createdAt])
}

model ContactMessage {
  id        String    @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean   @default(false)
  repliedAt DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([isRead])
  @@index([createdAt])
}

// --- Support Ticket System ---

enum TicketStatus {
  OPEN
  IN_PROGRESS
  AWAITING_REPLY
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum TicketCategory {
  GENERAL
  ACCOUNT
  BILLING
  TECHNICAL
  BUG_REPORT
  FEATURE_REQUEST
  JOB_POSTING
  APPLICATION
  VERIFICATION
  OTHER
}

enum TicketSatisfaction {
  SATISFIED
  NEUTRAL
  NOT_SATISFIED
}

model SupportTicket {
  id           String         @id @default(cuid())
  ticketNumber String         @unique
  subject      String
  description  String
  status       TicketStatus   @default(OPEN)
  priority     TicketPriority @default(MEDIUM)
  category     TicketCategory @default(GENERAL)

  // Submitter — either a registered user OR a guest
  userId     String?
  guestName  String?
  guestEmail String?

  // Assignment
  assignedToId String?

  // Resolution
  satisfaction        TicketSatisfaction?
  satisfactionComment String?
  resolvedAt          DateTime?
  closedAt            DateTime?
  firstResponseAt     DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user       User?           @relation("UserTickets", fields: [userId], references: [id], onDelete: SetNull)
  assignedTo User?           @relation("AssignedTickets", fields: [assignedToId], references: [id], onDelete: SetNull)
  messages   TicketMessage[]

  @@index([userId])
  @@index([assignedToId])
  @@index([status])
  @@index([ticketNumber])
  @@index([createdAt])
  @@index([category])
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  senderId   String?
  senderType String // USER, ADMIN, SYSTEM, GUEST
  senderName String
  subject    String?
  body       String   @db.Text
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
}

// --- Security & Privacy ---

model KnownDevice {
  id          String   @id @default(cuid())
  userId      String
  fingerprint String
  name        String?
  ipAddress   String?
  location    String?
  lastUsedAt  DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, fingerprint])
  @@index([userId])
}

model LoginLocation {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String
  country   String?
  city      String?
  latitude  Float?
  longitude Float?
  isTrusted Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model UserConsent {
  id        String    @id @default(cuid())
  userId    String
  type      String
  version   String
  givenAt   DateTime  @default(now())
  revokedAt DateTime?
  ipAddress String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
}

// --- MFA Trusted Devices (skip MFA for 30 days) ---

model MfaTrustedDevice {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  userAgent String?
  ipAddress String?
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

// --- Job Alerts ---

enum AlertFrequency {
  INSTANT
  DAILY
  WEEKLY
  OFF
}

model JobAlert {
  id             String         @id @default(uuid())
  userId         String
  name           String
  filters        Json
  frequency      AlertFrequency @default(DAILY)
  isActive       Boolean        @default(true)
  lastNotifiedAt DateTime?
  newMatchCount  Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isActive])
  @@index([isActive, frequency])
}

// --- Dismissed Recommendations ---

model DismissedRecommendation {
  id        String   @id @default(uuid())
  userId    String
  jobId     String
  createdAt DateTime @default(now())

  user User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  job  JobPost @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([userId, jobId])
  @@index([userId])
}

// --- Kafka DLQ Messages ---

model KafkaDlqMessage {
  id            String    @id @default(uuid())
  originalTopic String
  partition     Int
  offset        String
  originalValue String?   @db.Text
  error         String?   @db.Text
  stack         String?   @db.Text
  timestamp     DateTime
  replayed      Boolean   @default(false)
  replayedAt    DateTime?
  createdAt     DateTime  @default(now())

  @@index([originalTopic])
  @@index([replayed])
}

// --- Kafka Event Store (for replay) ---

model KafkaEvent {
  id          String   @id @default(uuid())
  eventType   String
  key         String
  data        String   @db.Text
  publishedAt DateTime
  createdAt   DateTime @default(now())

  @@index([eventType])
  @@index([publishedAt])
}

// =====================================================================
// Billing / Payments / Subscriptions / Coupons / Invoices / Entitlements
// =====================================================================
// Razorpay-backed payment system. Webhook is source of truth.
// All amounts stored as integer paise (1 INR = 100 paise) unless noted.
// Migration: edit schema -> hand-roll SQL into prisma/migrations.
// =====================================================================

enum PlanCategory {
