  list      CandidateList @relation(fields: [listId], references: [id], onDelete: Cascade)
  candidate User          @relation("CandidateInLists", fields: [candidateId], references: [id], onDelete: Cascade)
  addedBy   User          @relation("ListMembersAddedBy", fields: [addedByUserId], references: [id], onDelete: Cascade)

  @@unique([listId, candidateId])
  @@index([listId])
