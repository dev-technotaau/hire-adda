// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CANDIDATE
  EMPLOYER
  ADMIN
  SUPER_ADMIN
}

model User {
  id        String  @id @default(uuid())
  email     String  @unique
  password  String?
  role      Role    @default(CANDIDATE)
  firstName String?
  lastName  String?
  avatar    String?

  // Social Auth
  googleId   String? @unique
  linkedinId String? @unique

  // Mobile Auth
  mobileNumber              String?   @unique
  isMobileVerified          Boolean   @default(false)
  mobileVerificationToken   String?
  mobileVerificationExpires DateTime?

  // WhatsApp
  isWhatsappVerified          Boolean   @default(false)
  whatsappNumber              String? // Separate WhatsApp number (null = use mobileNumber)
  whatsappVerificationToken   String?
  whatsappVerificationExpires DateTime?

  // OTP resend tracking
  emailOtpResendCount    Int       @default(0)
  emailOtpLastSentAt     DateTime?
  mobileOtpResendCount   Int       @default(0)
  mobileOtpLastSentAt    DateTime?
  whatsappOtpResendCount Int       @default(0)
  whatsappOtpLastSentAt  DateTime?

  // Pending change fields (2-step email/mobile change)
  pendingEmail        String?
  pendingMobileNumber String?

  // Account Status
  isActive    Boolean   @default(true)
  isSuspended Boolean   @default(false)
  suspendedAt DateTime?
  suspendedBy String?

  // Email Verification
  isEmailVerified          Boolean   @default(false)
  emailVerificationToken   String?
  emailVerificationExpires DateTime?

  // Password Reset
  passwordResetToken   String?
  passwordResetExpires DateTime?

  // MFA (TOTP)
  mfaSecret      String?
  mfaEnabled     Boolean  @default(false)
  mfaBackupCodes String[] @default([])

  // MFA Recovery
  mfaRecoveryToken   String?
  mfaRecoveryExpires DateTime?

  // Account Security
  loginAttempts Int       @default(0)
  lockUntil     DateTime?
  lastLoginAt   DateTime?
  lastLoginIp   String?

  // Activity Tracking
  lastActiveAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]
  sessions      Session[]

  // Profiles
  candidateProfile CandidateProfile?
  companyProfile   CompanyProfile?
  savedJobs        SavedJob[]

  // Verifications
  verificationRequests  VerificationRequest[] @relation("UserVerifications")
  reviewedVerifications VerificationRequest[] @relation("AdminReviews")

  // Notifications, Drafts, Devices
  notifications     Notification[]
  formDrafts        FormDraft[]
  pushSubscriptions PushSubscription[]
  deviceTokens      DeviceToken[]

  // Saved Candidates & Searches
  savedCandidates      SavedCandidate[]      @relation("EmployerSavedCandidates")
  savedByEmployers     SavedCandidate[]      @relation("CandidateSavedBy")
  savedSearches        SavedSearch[]
  candidateLists       CandidateList[]       @relation("EmployerCandidateLists")
  candidateListMembers CandidateListMember[] @relation("CandidateInLists")
  addedListMembers     CandidateListMember[] @relation("ListMembersAddedBy")
  jobMatches           JobCandidateMatch[]   @relation("CandidateMatches")

  // WebAuthn & Webhooks
  webauthnCredentials WebAuthnCredential[]
  webhookEndpoints    WebhookEndpoint[]

  // Support Tickets
  tickets         SupportTicket[] @relation("UserTickets")
  assignedTickets SupportTicket[] @relation("AssignedTickets")

  // Profile Views
  profileViews    ProfileView[] @relation("ProfileViewer")
  profileViewedBy ProfileView[] @relation("ProfileViewed")

  // Job Alerts & Recommendations
  jobAlerts                JobAlert[]
  dismissedRecommendations DismissedRecommendation[]

  // Security & Privacy
  deletionRequestedAt  DateTime?
  knownDevices         KnownDevice[]
  loginLocations       LoginLocation[]
  consents             UserConsent[]
  mfaTrustedDevices    MfaTrustedDevice[]

  @@index([email])
  @@index([role])
  @@index([emailVerificationToken])
  @@index([passwordResetToken])
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  isRevoked Boolean  @default(false)
  createdAt DateTime @default(now())

  // Device info
  userAgent String?
  ipAddress String?

  // Link to session
  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@index([sessionId])
}

model Session {
  id         String   @id @default(uuid())
  userId     String
  userAgent  String?
  ipAddress  String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now()) @updatedAt
  lastSeenAt DateTime @default(now())

  user          User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshTokens RefreshToken[]

  @@index([userId])
  @@index([isActive])
  @@index([userId, isActive])
}

model AuditLog {
  id          String   @id @default(uuid())
  action      String // e.g., "CREATE_JOB", "DELETE_USER"
  entity      String // e.g., "Job", "User"
  entityId    String? // ID of the affected entity
  performedBy String? // User ID of who performed the action
  details     Json? // Additional context (e.g., diff of changes)
  ipAddress   String?
  userAgent   String?
  checksum    String? // SHA-256 integrity checksum
  isArchived  Boolean  @default(false)
  createdAt   DateTime @default(now())

  // Relations
  user User? @relation(fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([performedBy])
  @@index([action])
  @@index([entity])
  @@index([createdAt])
}

