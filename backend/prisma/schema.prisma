  BOOLEAN
  ENUM
  TEXT
}

enum OrderStatus {
  CREATED
  ATTEMPTED
  PAID
  FAILED
  CANCELLED
  EXPIRED
  REFUND_PENDING
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED
  FRAUD_FLAGGED
