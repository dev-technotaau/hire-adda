  PENDING
  CALL_SCHEDULED
  IN_PROGRESS
  DELIVERED
  COMPLETED
  CANCELLED
}

model AssistedHiringRequest {
  id                String               @id @default(uuid())
  employerId        String
  orderId           String?              @unique
  jobPostId         String?
  roleTitle         String
  requirementText   String
  preferredSkills   String[]             @default([])
  preferredLocation String?
  budgetRange       String?
  noticePeriod      String?
  contactEmail      String
  contactPhone      String?
  status            AssistedHiringStatus @default(PENDING)
  internalNotes     String?
  callScheduledAt   DateTime?
  deliveredAt       DateTime?
  startedAt         DateTime             @default(now())
  expiresAt         DateTime?
  assignedAdminId   String?
  createdAt         DateTime             @default(now())
